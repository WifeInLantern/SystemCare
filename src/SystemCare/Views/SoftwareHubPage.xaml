<Page x:Class="SystemCare.Views.SoftwareHubPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:SoftwareHubViewModel}"
      Title="Software Hub"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,24" helpers:Animations.StaggerChildren="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Software Hub" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Install popular free apps in one click via the Windows Package Manager (winget)."
                       FontSize="13" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,14,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" MaxWidth="420" HorizontalAlignment="Left"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Search all winget packages…"
                        Icon="{ui:SymbolIcon Search24}" ClearButtonEnabled="True" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button Content="Refresh" Appearance="Primary" Padding="20,8"
                           Command="{Binding RefreshCommand}"
                           IsEnabled="{Binding IsChecking, Converter={StaticResource Not}}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowSync24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Cancel" Padding="16,8" Margin="8,0,0,0"
                           Command="{Binding RefreshCancelCommand}"
                           Visibility="{Binding IsChecking, Converter={StaticResource VisibleWhenTrue}}" />
            </StackPanel>
        </Grid>

        <!-- winget unavailable -->
        <ui:InfoBar Grid.Row="2" Severity="Warning" IsOpen="True" Margin="0,0,0,4"
                    Title="Windows Package Manager not found"
                    Message="Install 'App Installer' from the Microsoft Store to enable the Software Hub."
                    Visibility="{Binding IsWingetMissing, Converter={StaticResource VisibleWhenTrue}}" />

        <!-- Status + progress -->
        <StackPanel Grid.Row="3" Margin="0,0,0,4">
            <controls:TaskProgress IsActive="{Binding IsChecking}" />
            <controls:TaskProgress IsActive="{Binding IsInstalling}" Value="{Binding InstallProgress}" />
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{StaticResource TextFillColorTertiaryBrush}" Margin="0,6,0,0"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <!-- Catalog header -->
        <Grid Grid.Row="4" Margin="0,12,0,0"
              Visibility="{Binding ShowCatalog, Converter={StaticResource VisibleWhenTrue}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="APP CATALOG" Style="{StaticResource CyberSectionHeader}"
                       VerticalAlignment="Center" />
            <ui:Button Grid.Column="1" Content="Install selected" Appearance="Primary" Padding="18,7"
                       Command="{Binding InstallSelectedCommand}"
                       IsEnabled="{Binding IsInstalling, Converter={StaticResource Not}}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowDownload24" /></ui:Button.Icon>
            </ui:Button>
        </Grid>

        <Grid Grid.Row="5">
            <!-- Catalog list, grouped by category -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0"
                          Visibility="{Binding ShowCatalog, Converter={StaticResource VisibleWhenTrue}}">
                <ItemsControl ItemsSource="{Binding GroupedApps}">
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource CyberSectionHeader}" Margin="0,12,0,6" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected}"
                                              IsEnabled="{Binding IsInstalled, Converter={StaticResource Not}}" />
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource TextCaption}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ui:Badge Grid.Column="2" Appearance="Success" VerticalAlignment="Center"
                                              Visibility="{Binding IsInstalled, Converter={StaticResource VisibleWhenTrue}}">
                                        <TextBlock Text="Installed" FontSize="11" />
                                    </ui:Badge>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Search results (replace the catalog while a search is active) -->
            <Grid Visibility="{Binding IsSearchMode, Converter={StaticResource VisibleWhenTrue}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,12,0,4">
                    <TextBlock Text="SEARCH RESULTS" Style="{StaticResource CyberSectionHeader}" />
                    <controls:TaskProgress IsActive="{Binding IsSearching}" />
                    <TextBlock Text="{Binding SearchStatusText}" FontSize="12" Foreground="{StaticResource TextFillColorTertiaryBrush}" Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                    <ItemsControl ItemsSource="{Binding SearchResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="0,0,0,6" Padding="14,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Id}" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" Margin="10,0,0,0"
                                                           VerticalAlignment="Center" FontFamily="Consolas" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource TextCaption}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:Badge Appearance="Success" VerticalAlignment="Center" Margin="0,0,8,0"
                                                      Visibility="{Binding IsInstalled, Converter={StaticResource VisibleWhenTrue}}">
                                                <TextBlock Text="Installed" FontSize="11" />
                                            </ui:Badge>
                                            <ui:Button Content="Install" Appearance="Primary" Padding="16,6"
                                                       Command="{Binding DataContext.InstallOneCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                       CommandParameter="{Binding}"
                                                       Visibility="{Binding IsInstalled, Converter={StaticResource VisibleWhenFalse}}">
                                                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowDownload24" /></ui:Button.Icon>
                                            </ui:Button>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
