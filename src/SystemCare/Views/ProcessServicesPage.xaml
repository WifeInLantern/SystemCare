<Page x:Class="SystemCare.Views.ProcessServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:ProcessServicesViewModel}"
      Title="Processes &amp; Services"
      Loaded="OnPageLoaded" Unloaded="OnPageUnloaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Processes &amp; Services" Style="{StaticResource CyberPageTitle}" Margin="0,0,0,12" />

        <TabControl Grid.Row="1">
            <!-- Processes -->
            <TabItem Header="Processes">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ui:ListView Grid.Row="0" ItemsSource="{Binding Processes}"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ui:ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Name}" FontSize="11" Opacity="0.5" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Pid}" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                                    <TextBlock Grid.Column="2" Text="{Binding CpuText}" VerticalAlignment="Center" FontSize="12" />
                                    <TextBlock Grid.Column="3" Text="{Binding RamText}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" />
                                    <ui:Button Grid.Column="4" Content="End task" Appearance="Danger" Padding="12,5"
                                               Command="{Binding DataContext.EndProcessCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>
                    <TextBlock Grid.Row="1" Text="{Binding ProcessSummary}" FontSize="12" Opacity="0.65" Margin="0,8,0,0" />
                </Grid>
            </TabItem>

            <!-- Services -->
            <TabItem Header="Services">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Content="Refresh" Command="{Binding RefreshServicesCommand}" Padding="18,7">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="ArrowClockwise24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:TextBox Grid.Column="1" Margin="10,0,0,0" PlaceholderText="Search services…"
                                    Text="{Binding ServiceSearch, UpdateSourceTrigger=PropertyChanged}"
                                    Icon="{ui:SymbolIcon Search24}" />
                    </Grid>
                    <ui:ListView Grid.Row="1" ItemsSource="{Binding Services}"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ui:ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Name}" FontSize="11" Opacity="0.5" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding StartMode}" VerticalAlignment="Center" FontSize="12" Opacity="0.6" />
                                    <TextBlock Grid.Column="2" Text="{Binding StateText}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" />
                                    <ui:Button Grid.Column="3" Padding="12,5"
                                               Command="{Binding DataContext.ToggleServiceCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}">
                                        <ui:Button.Style>
                                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                <Setter Property="Content" Value="Stop" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                        <Setter Property="Content" Value="Start" />
                                                        <Setter Property="Appearance" Value="Success" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ui:Button.Style>
                                    </ui:Button>
                                </Grid>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>
                    <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="4" Margin="0,8,0,0"
                                 Visibility="{Binding IsServicesBusy, Converter={StaticResource VisibleWhenTrue}}" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
