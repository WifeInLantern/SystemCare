<Page x:Class="SystemCare.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
      Title="Settings">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,12,24,24">
        <StackPanel MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource CyberPageTitle}" />

            <TextBlock Text="Appearance" Style="{StaticResource CyberSectionHeader}" Margin="0,20,0,8" />
            <ui:Card Padding="16,12">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Color24" FontSize="20" Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center" />
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Cyberpunk (Night City)" FontWeight="SemiBold" />
                        <TextBlock Text="A neon cyan + magenta dark theme with an animated backdrop. SystemCare is dark-only." FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <TextBlock Text="Automatic maintenance" Style="{StaticResource CyberSectionHeader}" Margin="0,20,0,8" />
            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Run maintenance on a schedule" FontWeight="SemiBold" />
                        <TextBlock Text="Cleans junk and trims memory automatically via a Windows scheduled task" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoMaintenanceEnabled}" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Frequency" FontWeight="SemiBold" />
                        <TextBlock Text="Off = daily at noon, On = weekly (Sunday)" FontSize="12" Opacity="0.65" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Weekly" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Opacity="0.8" />
                        <ui:ToggleSwitch IsChecked="{Binding IsWeekly}" />
                    </StackPanel>
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="What scheduled maintenance does" FontWeight="SemiBold" />
                    <TextBlock Text="Pick the steps the scheduled run (and the tray's 'Run maintenance now') performs"
                               FontSize="12" Opacity="0.65" TextWrapping="Wrap" Margin="0,0,0,6" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Clean junk files" VerticalAlignment="Center" />
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MaintenanceCleanJunk}" />
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Trim RAM" VerticalAlignment="Center" />
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MaintenanceTrimRam}" />
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Flush DNS cache" VerticalAlignment="Center" />
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MaintenanceFlushDns}" />
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Empty Recycle Bin" VerticalAlignment="Center" />
                        <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MaintenanceEmptyRecycleBin}" />
                    </Grid>
                </StackPanel>
            </ui:Card>
            <ui:Card Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Minimize to system tray" FontWeight="SemiBold" />
                        <TextBlock Text="Keep SystemCare running in the tray when closed or minimized" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding MinimizeToTray}" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Start with Windows" FontWeight="SemiBold" />
                        <TextBlock Text="Launch SystemCare minimized to the tray when you sign in (via an elevated logon task, so there's no UAC prompt)" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding StartWithWindows}" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Create a restore point before maintenance" FontWeight="SemiBold" />
                        <TextBlock Text="A System Restore point is made before 'Fix all' and disk repairs (if System Protection is on)" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CreateRestorePointBeforeMaintenance}" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Ask before each backup" FontWeight="SemiBold" />
                        <TextBlock Text="Confirm with a Yes/No prompt each time, instead of creating the restore point automatically" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding AskBeforeBackup}" IsEnabled="{Binding CreateRestorePointBeforeMaintenance}" />
                </Grid>
            </ui:Card>

            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Reduce motion &amp; effects" FontWeight="SemiBold" />
                        <TextBlock Text="Turns off the animated background and looping neon glows for better accessibility and battery life" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ReduceMotion}" />
                </Grid>
            </ui:Card>

            <TextBlock Text="Live monitor" Style="{StaticResource CyberSectionHeader}" Margin="0,20,0,8" />
            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Live stats in the tray icon" FontWeight="SemiBold" />
                        <TextBlock Text="Shows live CPU load on the tray icon, with CPU/RAM in its tooltip" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowTrayStats}" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Floating mini-widget" FontWeight="SemiBold" />
                        <TextBlock Text="A small always-on-top panel with live CPU/RAM/network sparklines and temperature. Drag to move; close with the ✕." FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowMiniMonitor}" />
                </Grid>
            </ui:Card>

            <TextBlock Text="Resource alerts" Style="{StaticResource CyberSectionHeader}" Margin="0,20,0,8" />
            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Alert on sustained high usage" FontWeight="SemiBold" />
                        <TextBlock Text="Toast + tray notification when CPU, RAM, or disk space stays above its threshold for too long" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding ResourceAlertsEnabled}" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12" Margin="0,0,0,8" IsEnabled="{Binding ResourceAlertsEnabled}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="CPU threshold (%)" FontWeight="SemiBold" />
                        <TextBlock Text="Alert when CPU usage stays at or above this" FontSize="12" Opacity="0.65" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Value="{Binding CpuAlertThresholdPercent}" Minimum="1" Maximum="100" Width="130"
                                  SpinButtonPlacementMode="Compact" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12" Margin="0,0,0,8" IsEnabled="{Binding ResourceAlertsEnabled}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="RAM threshold (%)" FontWeight="SemiBold" />
                        <TextBlock Text="Alert when memory usage stays at or above this" FontSize="12" Opacity="0.65" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Value="{Binding RamAlertThresholdPercent}" Minimum="1" Maximum="100" Width="130"
                                  SpinButtonPlacementMode="Compact" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12" Margin="0,0,0,8" IsEnabled="{Binding ResourceAlertsEnabled}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Disk space threshold (%)" FontWeight="SemiBold" />
                        <TextBlock Text="Alert when a fixed drive's usage stays at or above this" FontSize="12" Opacity="0.65" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Value="{Binding DiskAlertThresholdPercent}" Minimum="1" Maximum="100" Width="130"
                                  SpinButtonPlacementMode="Compact" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12" IsEnabled="{Binding ResourceAlertsEnabled}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Sustained for (minutes)" FontWeight="SemiBold" />
                        <TextBlock Text="How long usage must stay above the threshold before alerting" FontSize="12" Opacity="0.65" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Value="{Binding AlertSustainedMinutes}" Minimum="1" Maximum="120" Width="130"
                                  SpinButtonPlacementMode="Compact" />
                </Grid>
            </ui:Card>

            <TextBlock Text="Cleaning" Style="{StaticResource CyberSectionHeader}" Margin="0,20,0,8" />
            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Skip temp files newer than (hours)" FontWeight="SemiBold" />
                        <TextBlock Text="Protects files that running programs may still be using" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Value="{Binding SkipTempNewerThanHours}" Minimum="0" Maximum="720" Width="130"
                                  SpinButtonPlacementMode="Compact" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Excluded folders (never cleaned)" FontWeight="SemiBold" />
                    <TextBlock Text="The cleaner will skip anything inside these paths." FontSize="12" Opacity="0.65" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Exclusions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    <ui:Button Grid.Column="1" Padding="6,4" Appearance="Danger" ToolTip="Remove"
                                               Command="{Binding DataContext.RemoveExclusionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                                    </ui:Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ui:Button Content="Add folder…" Margin="0,8,0,0" Padding="12,6" Command="{Binding AddExclusionCommand}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="FolderAdd24" /></ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
            </ui:Card>
            <ui:Card Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Custom folders to clean" FontWeight="SemiBold" />
                    <TextBlock Text="Extra folders scanned for old files (same age rule as temp files)." FontSize="12" Opacity="0.65" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding CustomFolders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    <ui:Button Grid.Column="1" Padding="6,4" Appearance="Danger" ToolTip="Remove"
                                               Command="{Binding DataContext.RemoveCustomFolderCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}">
                                        <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                                    </ui:Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ui:Button Content="Add folder…" Margin="0,8,0,0" Padding="12,6" Command="{Binding AddCustomFolderCommand}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="FolderAdd24" /></ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
            </ui:Card>

            <TextBlock Text="Disk tools" Style="{StaticResource CyberSectionHeader}" Margin="0,14,0,8" />
            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Large file threshold (MB)" FontWeight="SemiBold" />
                        <TextBlock Text="Files at least this big are listed by the disk analyzer" FontSize="12" Opacity="0.65" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Value="{Binding LargeFileMinMB}" Minimum="1" Maximum="102400" Width="130"
                                  SpinButtonPlacementMode="Compact" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Number of large files to keep" FontWeight="SemiBold" />
                        <TextBlock Text="How many of the biggest files the analyzer reports" FontSize="12" Opacity="0.65" />
                    </StackPanel>
                    <ui:NumberBox Grid.Column="1" Value="{Binding LargeFileTopN}" Minimum="5" Maximum="500" Width="130"
                                  SpinButtonPlacementMode="Compact" />
                </Grid>
            </ui:Card>

            <TextBlock Text="Dashboard quick-actions" Style="{StaticResource CyberSectionHeader}" Margin="0,20,0,8" />
            <ui:Card Padding="16,12">
                <StackPanel>
                    <TextBlock Text="Choose which one-click tiles appear on the dashboard." FontSize="12" Opacity="0.65" Margin="0,0,0,8" />
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox Content="Scan &amp; Fix" IsChecked="{Binding QaScanFix}" Margin="0,0,20,6" />
                        <CheckBox Content="Free up RAM" IsChecked="{Binding QaFreeRam}" Margin="0,0,20,6" />
                        <CheckBox Content="Flush DNS" IsChecked="{Binding QaFlushDns}" Margin="0,0,20,6" />
                        <CheckBox Content="Empty Recycle Bin" IsChecked="{Binding QaEmptyBin}" Margin="0,0,20,6" />
                        <CheckBox Content="Create restore point" IsChecked="{Binding QaRestorePoint}" Margin="0,0,20,6" />
                    </WrapPanel>
                </StackPanel>
            </ui:Card>

            <TextBlock Text="Updates" Style="{StaticResource CyberSectionHeader}" Margin="0,20,0,8" />
            <ui:Card Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Download updates on startup" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding UpdateStatus}" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" IsChecked="{Binding CheckForUpdatesOnStartup}" VerticalAlignment="Center" />
                </Grid>
            </ui:Card>
            <ui:Card Padding="16,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Check for updates" Command="{Binding CheckForUpdatesCommand}" Padding="16,8">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowSync24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Download &amp; install" Appearance="Primary" Margin="8,0,0,0" Padding="16,8"
                                   Command="{Binding DownloadAndInstallCommand}"
                                   Visibility="{Binding UpdateAvailable, Converter={StaticResource VisibleWhenTrue}}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowDownload24" /></ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                    <ProgressBar Value="{Binding DownloadProgress}" Maximum="100" Height="6" Margin="0,10,0,0"
                                 Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource VisibleWhenTrue}}" />
                    <StackPanel Margin="0,14,0,0">
                        <TextBlock Text="GitHub access token" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Only needed when the update repo is private. Stored encrypted on this PC (Windows DPAPI, tied to your account); clear the box to remove it."
                                   FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,2,0,4" />
                        <ui:TextBox PlaceholderText="github_pat_…"
                                    Text="{Binding UpdateGitHubToken, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <TextBlock Text="About" Style="{StaticResource CyberSectionHeader}" Margin="0,20,0,8" />
            <ui:Card Padding="16,12">
                <StackPanel>
                    <TextBlock Text="{Binding VersionText}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ElevationText}" FontSize="12" Opacity="0.7" Margin="0,4,0,10" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Open settings folder" Command="{Binding OpenSettingsFolderCommand}" Padding="14,7">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="FolderOpen24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Open logs folder" Command="{Binding OpenLogsFolderCommand}" Padding="14,7" Margin="8,0,0,0"
                                   ToolTip="Diagnostic logs for maintenance, updates and errors">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="History24" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
