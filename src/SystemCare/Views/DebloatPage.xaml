<Page x:Class="SystemCare.Views.DebloatPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:DebloatViewModel}"
      Title="Debloat">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Debloat Windows" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Disable telemetry, ads and unneeded services, and remove preinstalled bloat. Tweaks are reversible; app removal is permanent. A restore point is created first."
                       FontSize="13" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0" Content="Create a restore point first" VerticalAlignment="Center"
                      IsChecked="{Binding CreateRestorePoint}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button Content="Apply selected" Appearance="Primary" Padding="20,8"
                           Command="{Binding ApplyCommand}" IsEnabled="{Binding IsRunning, Converter={StaticResource Not}}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Broom24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Revert selected" Padding="16,8" Margin="8,0,0,0"
                           Command="{Binding RevertCommand}" IsEnabled="{Binding IsRunning, Converter={StaticResource Not}}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowUndo24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Cancel" Appearance="Danger" Padding="14,8" Margin="8,0,0,0"
                           Command="{Binding CancelCommand}"
                           Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
                <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="12,0,0,0"
                                 Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <ItemsControl ItemsSource="{Binding GroupedItems}">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Style="{StaticResource CyberSectionHeader}" Margin="0,12,0,6" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ItemsControl.GroupStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,6" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Description}" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Warning}" FontSize="12" Foreground="{StaticResource WarningBrush}"
                                               TextWrapping="Wrap" Margin="0,3,0,0"
                                               Visibility="{Binding HasWarning, Converter={StaticResource VisibleWhenTrue}}" />
                                </StackPanel>
                                <Border Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0"
                                        CornerRadius="3" Padding="7,2" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource CyberStrokeBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Reversible}" Value="False">
                                                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                                    <Setter Property="Background" Value="#22FF2A6D" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding BadgeText}" FontSize="10" Opacity="0.85" />
                                </Border>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" Margin="0,12,0,0" Background="#070C14" CornerRadius="6"
                BorderBrush="{StaticResource CyberStrokeBrush}" BorderThickness="1">
            <TextBox x:Name="OutputBox" Text="{Binding OutputText, Mode=OneWay}" IsReadOnly="True"
                     Background="Transparent" BorderThickness="0" Foreground="#9FE8FF"
                     FontFamily="Consolas, Cascadia Mono, monospace" FontSize="12"
                     TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     Padding="10" TextChanged="OnOutputChanged" />
        </Border>
    </Grid>
</Page>
