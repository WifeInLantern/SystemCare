<Page x:Class="SystemCare.Views.CleanupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:CleanupViewModel}"
      Title="Cleanup">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Junk Cleanup" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="{Binding TotalText}" FontSize="14" Opacity="0.8" Margin="0,6,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,14">
            <ui:Button Content="Scan" Appearance="Primary" Padding="26,8"
                       Command="{Binding ScanCommand}"
                       IsEnabled="{Binding IsBusy, Converter={StaticResource Not}}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Search24" />
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Cancel" Padding="20,8" Margin="10,0,0,0"
                       Command="{Binding ScanCancelCommand}"
                       Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            <ui:Button Content="Clean selected" Appearance="Success" Padding="26,8" Margin="10,0,0,0"
                       Command="{Binding CleanCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Broom24" />
                </ui:Button.Icon>
            </ui:Button>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Description}" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding SizeText}" FontWeight="SemiBold" FontSize="15"
                                               HorizontalAlignment="Right" Foreground="{StaticResource SuccessBrush}" />
                                    <TextBlock FontSize="11" Opacity="0.6" HorizontalAlignment="Right">
                                        <Run Text="{Binding FileCount, Mode=OneWay, StringFormat=N0}" /><Run Text=" files" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <ProgressBar IsIndeterminate="True" Height="4"
                         Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            <TextBlock Text="{Binding ProgressText}" FontSize="11" Opacity="0.55" Margin="0,6,0,0"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</Page>
