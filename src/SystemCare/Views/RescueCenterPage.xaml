<Page x:Class="SystemCare.Views.RescueCenterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:RescueCenterViewModel}"
      Title="Rescue Center"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Rescue Center" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="{Binding StatusText}" FontSize="13" Opacity="0.75" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
            <ui:Button Content="Create restore point now" Appearance="Primary" Padding="20,8" Command="{Binding CreateCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ShieldAdd24" />
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Open System Restore" Padding="18,8" Margin="8,0,0,0" Command="{Binding OpenSystemRestoreCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowUndo24" />
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Refresh" Padding="18,8" Margin="8,0,0,0" Appearance="Secondary" Command="{Binding RefreshCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowClockwise24" />
                </ui:Button.Icon>
            </ui:Button>
        </StackPanel>

        <controls:TaskProgress Grid.Row="2" IsActive="{Binding IsBusy}" Margin="0,12,0,0" />

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <ItemsControl ItemsSource="{Binding Points}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="16,12" helpers:Animations.FadeInOnLoad="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Grid.Column="0" Symbol="History24" FontSize="22" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Description}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="12" Opacity="0.6">
                                        <Run Text="{Binding CreationTime, Mode=OneWay, StringFormat=g}" /><Run Text="  ·  " /><Run Text="{Binding TypeText, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11" Opacity="0.5">
                                    <Run Text="#" /><Run Text="{Binding SequenceNumber, Mode=OneWay}" />
                                </TextBlock>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
