<Page x:Class="SystemCare.Views.DuplicateFinderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:DuplicateFinderViewModel}"
      Title="Duplicates">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Duplicate File Finder" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusText}" FontSize="13" Opacity="0.75" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ListBox Grid.Column="0" ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedRoot}"
                     MaxHeight="110" ScrollViewer.VerticalScrollBarVisibility="Auto" />
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <ui:Button Content="Add folder…" Padding="14,7" Command="{Binding AddFolderCommand}" HorizontalAlignment="Stretch">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="FolderAdd24" />
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Remove" Padding="14,7" Margin="0,6,0,0" Command="{Binding RemoveRootCommand}" HorizontalAlignment="Stretch" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Min size (MB):" VerticalAlignment="Center" FontSize="12" Opacity="0.8" />
                    <ui:NumberBox Value="{Binding MinSizeMB}" Minimum="0" Maximum="10240" Width="110" Margin="8,0,0,0"
                                  SpinButtonPlacementMode="Compact" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,10">
            <ui:Button Content="Find duplicates" Appearance="Primary" Padding="22,8"
                       Command="{Binding ScanCommand}"
                       IsEnabled="{Binding IsBusy, Converter={StaticResource Not}}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Search24" />
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Cancel" Padding="16,8" Margin="8,0,0,0"
                       Command="{Binding ScanCancelCommand}"
                       Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            <Separator Margin="14,0" />
            <ui:Button Content="Keep newest" Padding="14,8" Command="{Binding KeepNewestCommand}" />
            <ui:Button Content="Keep oldest" Padding="14,8" Margin="8,0,0,0" Command="{Binding KeepOldestCommand}" />
            <ui:Button Content="Clear selection" Padding="14,8" Margin="8,0,0,0" Command="{Binding ClearSelectionCommand}" />
            <ui:Button Content="Recycle selected" Appearance="Danger" Padding="18,8" Margin="14,0,0,0"
                       Command="{Binding DeleteSelectedCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Delete24" />
                </ui:Button.Icon>
            </ui:Button>
        </StackPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}" VirtualizingPanel.IsVirtualizing="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Header="{Binding Header}" Margin="0,0,0,8" IsExpanded="False">
                            <ItemsControl ItemsSource="{Binding Files}" Margin="12,6,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" />
                                            <TextBlock Grid.Column="1" Text="{Binding FullPath}" Margin="8,0"
                                                       VerticalAlignment="Center" FontSize="12"
                                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding FullPath}" />
                                            <TextBlock Grid.Column="2" Text="{Binding ModifiedText}" VerticalAlignment="Center"
                                                       FontSize="11" Opacity="0.6" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <ProgressBar IsIndeterminate="True" Height="4"
                         Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            <TextBlock Text="{Binding SelectionText}" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0" Foreground="#FFA726" />
        </StackPanel>
    </Grid>
</Page>
