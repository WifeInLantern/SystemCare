<Page x:Class="SystemCare.Views.BatteryHealthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:BatteryHealthViewModel}"
      Title="Battery Health"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True" />
    </Page.Resources>

    <Grid Margin="24,12,24,24" helpers:Animations.StaggerChildren="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Battery Health" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="{Binding SummaryText}" FontSize="13" Foreground="{StaticResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
            <ui:Button Content="Refresh" Padding="18,8" Command="{Binding RefreshCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowClockwise24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Export detailed report" Padding="18,8" Margin="10,0,0,0"
                       Command="{Binding ExportReportCommand}"
                       Visibility="{Binding HasBattery, Converter={StaticResource VisibleWhenTrue}}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentArrowRight24" /></ui:Button.Icon>
            </ui:Button>
            <TextBlock Text="{Binding ExportStatus}" VerticalAlignment="Center" Margin="12,0,0,0"
                       Opacity="0.8" FontSize="12" />
        </StackPanel>

        <!-- Empty state (desktops) -->
        <ui:Card Grid.Row="2" Padding="24,20" VerticalAlignment="Top" Margin="0,16,0,0"
                 Visibility="{Binding HasBattery, Converter={StaticResource VisibleWhenFalse}}">
            <StackPanel HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="BatteryWarning24" FontSize="40" HorizontalAlignment="Center" Opacity="0.7" />
                <TextBlock Text="No battery detected" FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,10,0,4" />
                <TextBlock Text="Battery health is only available on laptops and tablets."
                           Opacity="0.75" HorizontalAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
        </ui:Card>

        <!-- Battery detail -->
        <Grid Grid.Row="2" Margin="0,16,0,0"
              Visibility="{Binding HasBattery, Converter={StaticResource VisibleWhenTrue}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Health gauge -->
            <ui:Card Grid.Column="0" Padding="20,18" VerticalAlignment="Top">
                <StackPanel>
                    <controls:HealthGauge Width="200" Height="200"
                                          Score="{Binding HealthScore}"
                                          BandLabelOverride="{Binding HealthBand}"
                                          helpers:Animations.RevealOnLoad="True" />
                    <TextBlock Text="Overall health" HorizontalAlignment="Center" Foreground="{StaticResource TextFillColorSecondaryBrush}"
                               Margin="0,8,0,0" FontSize="13" />
                </StackPanel>
            </ui:Card>

            <!-- Details -->
            <ui:Card Grid.Column="1" Margin="12,0,0,0" Padding="18,16" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Details" Style="{StaticResource CyberSectionHeader}" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Battery" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding BatteryName}" FontWeight="SemiBold" TextAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Chemistry" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding ChemistryText}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Design capacity" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding DesignCapacityText}" FontWeight="SemiBold" TextAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Full-charge capacity" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding FullChargeCapacityText}" FontWeight="SemiBold" TextAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Wear level" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding WearText}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Cycle count" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding CycleCountText}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Current charge" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding ChargeText}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Power state" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding PowerStateText}" FontWeight="SemiBold" />
                    </Grid>
                </StackPanel>
            </ui:Card>
        </Grid>
    </Grid>
</Page>
