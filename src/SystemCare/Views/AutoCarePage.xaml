<Page x:Class="SystemCare.Views.AutoCarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:AutoCareViewModel}"
      Title="Auto Care">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,12,24,24" helpers:Animations.StaggerChildren="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Auto Care" Style="{StaticResource CyberPageTitle}" />
                <TextBlock Text="One click analyzes junk, startup load, memory pressure, security posture, and pending app updates — then explains exactly what to do about each."
                           FontSize="13" Opacity="0.75" Margin="0,4,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Analyze / cancel + progress -->
            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="Analyze this PC" Appearance="Primary" Padding="32,12" FontSize="15"
                               Command="{Binding AnalyzeCommand}"
                               Visibility="{Binding IsWorking, Converter={StaticResource VisibleWhenFalse}}"
                               helpers:Animations.RevealOnLoad="True"
                               helpers:Animations.EntranceSpring="True">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Sparkle24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Cancel" Appearance="Danger" Padding="32,12" FontSize="15"
                               Command="{Binding AnalyzeCancelCommand}"
                               Visibility="{Binding IsWorking, Converter={StaticResource VisibleWhenTrue}}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Stop24" /></ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
                <controls:TaskProgress IsActive="{Binding IsWorking}" Margin="0,10,0,0" />
                <TextBlock Text="{Binding ProgressText}" FontSize="12" Opacity="0.7" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Headline: gauge + summary -->
            <ui:Card Grid.Row="2" Margin="0,16,0,0" Padding="20,16"
                     Visibility="{Binding HasAnalyzed, Converter={StaticResource VisibleWhenTrue}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <controls:HealthGauge Grid.Column="0" Width="150" Height="150" Score="{Binding HealthScoreValue}" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                        <TextBlock Text="{Binding Headline}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Margin="0,6,0,0" Style="{StaticResource TextCaption}" TextWrapping="Wrap"
                                   Text="Direct fixes apply right here (with your restore-point safety net); review items open the matching tool." />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Recommendations -->
            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                <ui:InfoBar Severity="Success" IsOpen="True" Title="All clear"
                            Message="No junk worth cleaning, healthy startup list, relaxed RAM, no security flags, apps up to date."
                            Visibility="{Binding AllClear, Converter={StaticResource VisibleWhenTrue}}" />

                <ItemsControl ItemsSource="{Binding Recommendations}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,8" Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="4" CornerRadius="2" Background="{Binding SeverityBrush}"
                                            VerticalAlignment="Stretch" Margin="0,2,14,2" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="18" VerticalAlignment="Center"
                                                           Foreground="{Binding SeverityBrush}" />
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                                       VerticalAlignment="Center" Margin="10,0,0,0" />
                                            <Border Padding="7,2" CornerRadius="8" Margin="12,0,0,0"
                                                    BorderThickness="1" BorderBrush="{Binding SeverityBrush}" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SeverityText}" FontSize="9"
                                                           Foreground="{Binding SeverityBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Explanation}" FontSize="12" Opacity="0.75"
                                                   TextWrapping="Wrap" Margin="28,4,0,0" />
                                        <TextBlock Text="{Binding ImpactText}" FontSize="11" Margin="28,3,0,0"
                                                   Foreground="{StaticResource NeonCyanBrush}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0">
                                        <ui:Button Content="{Binding ActionLabel}" Appearance="Primary" Padding="20,7"
                                                   Command="{Binding DataContext.ApplyCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"
                                                   IsEnabled="{Binding IsBusy, Converter={StaticResource Not}}"
                                                   Visibility="{Binding IsDone, Converter={StaticResource VisibleWhenFalse}}" />
                                        <ui:Badge Appearance="Success"
                                                  Visibility="{Binding IsDone, Converter={StaticResource VisibleWhenTrue}}">
                                            <TextBlock Text="Done" FontSize="11" />
                                        </ui:Badge>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,10,0,0" FontSize="11" Opacity="0.55" TextWrapping="Wrap"
                           Visibility="{Binding HasAnalyzed, Converter={StaticResource VisibleWhenTrue}}"
                           Text="Analysis is read-only — nothing changes until you click Apply. Recommendations are ranked by how many health points each fix recovers." />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
