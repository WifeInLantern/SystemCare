<Page x:Class="SystemCare.Views.FileShredderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:FileShredderViewModel}"
      Title="File Shredder">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="File Shredder" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Permanently erase files by overwriting them before deletion. Shredded files cannot be recovered. (On SSDs, wear-levelling means overwriting isn't a 100% guarantee.)"
                       FontSize="13" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,14,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Content="Add files…" Padding="14,7" Command="{Binding AddFilesCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentAdd24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Grid.Column="1" Content="Add folder…" Padding="14,7" Margin="8,0,0,0" Command="{Binding AddFolderCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="FolderAdd24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Grid.Column="2" Content="Clear" Padding="14,7" Margin="8,0,0,0" Appearance="Secondary" Command="{Binding ClearCommand}" />
            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Passes:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Opacity="0.8" />
                <ui:NumberBox Value="{Binding Passes}" Minimum="1" Maximum="7" Width="100" SpinButtonPlacementMode="Compact" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2" Text="No items added yet — add files or a folder to shred."
                   FontSize="12" Opacity="0.5" Margin="0,0,0,8"
                   Visibility="{Binding HasItems, Converter={StaticResource VisibleWhenTrue}, ConverterParameter=invert}" />

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,6" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Grid.Column="0" Symbol="Document24" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.55" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding SizeText}" VerticalAlignment="Center" FontSize="12" Opacity="0.7" Margin="0,0,10,0" />
                                <ui:Button Grid.Column="3" Padding="6,4" Appearance="Secondary" ToolTip="Remove"
                                           Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}">
                                    <ui:Button.Icon><ui:SymbolIcon Symbol="Dismiss24" /></ui:Button.Icon>
                                </ui:Button>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <ProgressBar IsIndeterminate="True" Height="4"
                         Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            <TextBlock Text="{Binding ProgressText}" FontSize="11" Opacity="0.6" Margin="0,6,0,8" TextTrimming="CharacterEllipsis" />
            <StackPanel Orientation="Horizontal">
                <ui:Button Content="Shred permanently" Appearance="Danger" Padding="22,9" FontSize="14"
                           Command="{Binding ShredCommand}"
                           IsEnabled="{Binding IsBusy, Converter={StaticResource Not}}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Cancel" Padding="18,9" Margin="8,0,0,0"
                           Command="{Binding CancelCommand}"
                           Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
