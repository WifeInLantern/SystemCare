<Page x:Class="SystemCare.Views.RansomwareShieldPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:RansomwareShieldViewModel}"
      Title="Ransomware Shield"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <Grid Margin="24,12,24,24" helpers:Animations.StaggerChildren="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:Card Grid.Row="0" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="{Binding StatusIcon}" FontSize="40" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="16,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Ransomware Shield" Style="{StaticResource CyberPageTitle}" />
                    <TextBlock Text="{Binding Headline}" FontSize="13" Opacity="0.8" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
                <ui:Button Grid.Column="2" Content="{Binding ToggleLabel}" Appearance="Primary" Padding="18,9"
                           VerticalAlignment="Center" Command="{Binding ToggleCommand}" />
            </Grid>
        </ui:Card>

        <TextBlock Grid.Row="1" Margin="2,12,0,0" TextWrapping="Wrap" Opacity="0.8" FontSize="12"
                   Text="Uses Windows Defender's Controlled Folder Access. Your Documents, Pictures, Videos, Music, and Desktop are protected by default; any extra folders you've added appear below." />

        <WrapPanel Grid.Row="2" Margin="0,12,0,0">
            <ui:Button Content="Re-check" Padding="14,7" Margin="0,4,0,4" Command="{Binding RefreshCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowClockwise24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Manage in Windows Security" Padding="14,7" Margin="10,4,0,4" Command="{Binding OpenSecurityCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Open24" /></ui:Button.Icon>
            </ui:Button>
            <controls:TaskProgress IsActive="{Binding IsBusy}" Margin="14,0,0,0" VerticalAlignment="Center" />
        </WrapPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,14,0,0">
            <StackPanel>
                <TextBlock Text="Extra protected folders" Style="{StaticResource CyberSectionHeader}" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding ProtectedFolders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,6" Padding="14,10">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Folder24" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding}" Margin="10,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="No extra folders added — only the default system folders are protected."
                           Opacity="0.6" FontSize="12" Margin="2,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ProtectedFolders.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
