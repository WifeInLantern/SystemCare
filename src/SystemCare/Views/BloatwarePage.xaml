<Page x:Class="SystemCare.Views.BloatwarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:BloatwareViewModel}"
      Title="Bloatware"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Bloatware &amp; Store Apps" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Remove Microsoft Store / built-in apps. System-critical packages are hidden for safety."
                       FontSize="13" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,14,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Content="Refresh" Padding="16,7" Command="{Binding RefreshCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowClockwise24" /></ui:Button.Icon>
            </ui:Button>
            <ui:TextBox Grid.Column="1" Margin="10,0" PlaceholderText="Search by name or publisher…"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Icon="{ui:SymbolIcon Search24}" />
            <CheckBox Grid.Column="2" Content="Bloatware only" IsChecked="{Binding BloatwareOnly}" VerticalAlignment="Center" />
        </Grid>

        <ui:ListView Grid.Row="2" ItemsSource="{Binding Items}" VirtualizingPanel.IsVirtualizing="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ui:ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding Name}" FontSize="11" Opacity="0.55" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Border Grid.Column="2" Background="#33FF2A6D" CornerRadius="9" Padding="8,2" Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsBloatware, Converter={StaticResource VisibleWhenTrue}}">
                            <TextBlock Text="bloatware" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource NeonMagentaBrush}" />
                        </Border>
                        <TextBlock Grid.Column="3" Text="{Binding Publisher}" FontSize="11" Opacity="0.6"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ui:ListView.ItemTemplate>
        </ui:ListView>

        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <ProgressBar IsIndeterminate="True" Height="4"
                         Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                <ui:Button Grid.Column="1" Content="Remove selected" Appearance="Danger" Padding="20,8"
                           Command="{Binding RemoveSelectedCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                </ui:Button>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
