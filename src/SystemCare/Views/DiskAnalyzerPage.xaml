<Page x:Class="SystemCare.Views.DiskAnalyzerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:DiskAnalyzerViewModel}"
      Title="Disk Analyzer">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
        <converters:PercentToBarWidthConverter x:Key="PercentToBarWidth" />
    </Page.Resources>

    <Grid Margin="24,12,24,24" helpers:Animations.StaggerChildren="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Disk Space Analyzer" Style="{StaticResource CyberPageTitle}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,10">
            <ComboBox MinWidth="220" ItemsSource="{Binding ScanTargets}" SelectedItem="{Binding SelectedTarget}" />
            <ui:Button Content="Browse…" Margin="10,0,0,0" Padding="16,7" Command="{Binding PickFolderCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="FolderOpen24" />
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Scan" Appearance="Primary" Margin="10,0,0,0" Padding="26,7"
                       Command="{Binding ScanCommand}"
                       IsEnabled="{Binding IsBusy, Converter={StaticResource Not}}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Search24" />
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Cancel" Margin="10,0,0,0" Padding="16,7"
                       Command="{Binding ScanCancelCommand}"
                       Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
        </StackPanel>

        <!-- Column header -->
        <Grid Grid.Row="2" Margin="6,0,8,6" Visibility="{Binding HasResult, Converter={StaticResource VisibleWhenTrue}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="58" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Name" FontSize="11" Opacity="0.55" />
                <TextBlock Grid.Column="1" Text="Relative size" FontSize="11" Opacity="0.55" Margin="6,0" />
                <TextBlock Grid.Column="2" Text="Size" FontSize="11" Opacity="0.55" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="3" Text="%" FontSize="11" Opacity="0.55" HorizontalAlignment="Right" />
            </Grid>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- TreeSize-style hierarchy: expand folders to see exactly what uses space -->
            <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" Background="{StaticResource CyberBackgroundBrush}"
                    BorderBrush="{StaticResource CyberStrokeBrush}" BorderThickness="1">
                <TreeView ItemsSource="{Binding TreeRoots}" Background="Transparent" BorderThickness="0"
                          Padding="4"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:DiskNodeViewModel}" ItemsSource="{Binding Children}">
                            <Grid Height="26">
                                <Grid.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Open in Explorer" Command="{Binding OpenCommand}" />
                                        <MenuItem Header="Move to Recycle Bin…" Command="{Binding DeleteCommand}" />
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="15" Margin="0,0,8,0"
                                                   Foreground="{Binding BarBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding FullPath}" />
                                </StackPanel>

                                <Border Grid.Column="1" Height="8" Margin="6,0" VerticalAlignment="Center"
                                        Background="{StaticResource Surface2Brush}" CornerRadius="4" ClipToBounds="True">
                                    <Border HorizontalAlignment="Left" CornerRadius="4" Background="{Binding BarBrush}"
                                            Width="{Binding Percent, Converter={StaticResource PercentToBarWidth}, ConverterParameter=104}" />
                                </Border>

                                <TextBlock Grid.Column="2" Text="{Binding SizeText}" VerticalAlignment="Center"
                                           HorizontalAlignment="Right" FontSize="12" Foreground="{StaticResource WarningBrush}" />
                                <TextBlock Grid.Column="3" Text="{Binding PercentText}" VerticalAlignment="Center"
                                           HorizontalAlignment="Right" FontSize="11" Opacity="0.65" />
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <Grid Grid.Column="1" Margin="14,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Largest files" Style="{StaticResource CyberSectionHeader}" Margin="0,0,0,8" />
                <ui:ListView Grid.Row="1" ItemsSource="{Binding LargeFiles}"
                             VirtualizingPanel.IsVirtualizing="True">
                    <ui:ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Entry.FullPath}" />
                                    <TextBlock Text="{Binding SizeText}" FontSize="11" Foreground="{StaticResource WarningBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:Button Padding="6,4" Appearance="Secondary" ToolTip="Open in Explorer"
                                               Command="{Binding OpenCommand}">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="FolderOpen24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Padding="6,4" Margin="4,0,0,0" Appearance="Danger" ToolTip="Move to Recycle Bin"
                                               Command="{Binding DeleteCommand}">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Delete24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <controls:TaskProgress IsActive="{Binding IsBusy}" />
            <TextBlock Text="{Binding ProgressText}" FontSize="11" Opacity="0.6" Margin="0,6,0,0"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</Page>
