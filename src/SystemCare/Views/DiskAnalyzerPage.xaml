<Page x:Class="SystemCare.Views.DiskAnalyzerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:DiskAnalyzerViewModel}"
      Title="Disk Analyzer">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Disk Space Analyzer" Style="{StaticResource CyberPageTitle}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,10">
            <ComboBox MinWidth="220" ItemsSource="{Binding ScanTargets}" SelectedItem="{Binding SelectedTarget}" />
            <ui:Button Content="Browse…" Margin="10,0,0,0" Padding="16,7" Command="{Binding PickFolderCommand}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="FolderOpen24" />
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Scan" Appearance="Primary" Margin="10,0,0,0" Padding="26,7"
                       Command="{Binding ScanCommand}"
                       IsEnabled="{Binding IsBusy, Converter={StaticResource Not}}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Search24" />
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Cancel" Margin="10,0,0,0" Padding="16,7"
                       Command="{Binding ScanCancelCommand}"
                       Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
        </StackPanel>

        <!-- Breadcrumbs -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Breadcrumbs}" Margin="0,0,0,8"
                      Visibility="{Binding HasResult, Converter={StaticResource VisibleWhenTrue}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="{Binding Name}" Padding="8,4" Appearance="Transparent"
                                   Command="{Binding DataContext.NavigateBreadcrumbCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                   CommandParameter="{Binding}" />
                        <TextBlock Text="›" VerticalAlignment="Center" Opacity="0.5" Margin="2,0" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" Background="#0A0E14">
                <controls:TreemapControl x:Name="Treemap" RootNode="{Binding CurrentRoot}" />
            </Border>

            <Grid Grid.Column="1" Margin="14,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Largest files" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ui:ListView Grid.Row="1" ItemsSource="{Binding LargeFiles}"
                             VirtualizingPanel.IsVirtualizing="True">
                    <ui:ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding Entry.FullPath}" />
                                    <TextBlock Text="{Binding SizeText}" FontSize="11" Foreground="{StaticResource WarningBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:Button Padding="6,4" Appearance="Secondary" ToolTip="Open in Explorer"
                                               Command="{Binding OpenCommand}">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="FolderOpen24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                    <ui:Button Padding="6,4" Margin="4,0,0,0" Appearance="Danger" ToolTip="Move to Recycle Bin"
                                               Command="{Binding DeleteCommand}">
                                        <ui:Button.Icon>
                                            <ui:SymbolIcon Symbol="Delete24" />
                                        </ui:Button.Icon>
                                    </ui:Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ui:ListView.ItemTemplate>
                </ui:ListView>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <ProgressBar IsIndeterminate="True" Height="4"
                         Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            <TextBlock Text="{Binding ProgressText}" FontSize="11" Opacity="0.6" Margin="0,6,0,0"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding HoverText}" FontSize="11" Opacity="0.8" Margin="0,2,0,0"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</Page>
