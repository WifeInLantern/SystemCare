<Page x:Class="SystemCare.Views.WindowsUpdatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:WindowsUpdateViewModel}"
      Title="Windows Update"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,24" helpers:Animations.StaggerChildren="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Windows Update" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Check, install, or pause Windows (non-driver) updates. A restore point is created before installing."
                       FontSize="13" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,8">
            <ui:Button Content="Check for updates" Appearance="Primary" Padding="20,8"
                       Command="{Binding CheckCommand}"
                       IsEnabled="{Binding IsChecking, Converter={StaticResource Not}}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowSync24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Cancel" Padding="16,8" Margin="8,0,0,0"
                       Command="{Binding CheckCancelCommand}"
                       Visibility="{Binding IsChecking, Converter={StaticResource VisibleWhenTrue}}" />
            <ui:Button Content="Windows Update settings" Padding="14,8" Margin="8,0,0,0"
                       Command="{Binding OpenWindowsUpdateCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Settings24" /></ui:Button.Icon>
            </ui:Button>
        </StackPanel>

        <!-- Pause controls -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
            <ui:SymbolIcon Symbol="PauseCircle24" FontSize="16" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="Pause updates:" VerticalAlignment="Center" Foreground="{StaticResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" />
            <ui:Button Content="7 days" Padding="12,5" Margin="0,0,6,0" Command="{Binding PauseCommand}" CommandParameter="7" />
            <ui:Button Content="14 days" Padding="12,5" Margin="0,0,6,0" Command="{Binding PauseCommand}" CommandParameter="14" />
            <ui:Button Content="35 days" Padding="12,5" Margin="0,0,12,0" Command="{Binding PauseCommand}" CommandParameter="35" />
            <ui:Button Content="Resume" Appearance="Secondary" Padding="12,5" Command="{Binding ResumeCommand}" />
            <TextBlock Text="{Binding PauseStatus}" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12" Foreground="{StaticResource TextFillColorTertiaryBrush}" />
        </StackPanel>

        <!-- Status + progress -->
        <StackPanel Grid.Row="3" Margin="0,8,0,0">
            <controls:TaskProgress IsActive="{Binding IsChecking}" />
            <controls:TaskProgress IsActive="{Binding IsInstalling}" Value="{Binding InstallProgress}" />
            <Grid Margin="0,6,0,0" Visibility="{Binding HasChecked, Converter={StaticResource VisibleWhenTrue}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" FontSize="12" Foreground="{StaticResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <ui:Button Grid.Column="1" Content="Install selected" Appearance="Primary" Padding="18,7"
                           Command="{Binding InstallSelectedCommand}"
                           IsEnabled="{Binding IsInstalling, Converter={StaticResource Not}}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowDownload24" /></ui:Button.Icon>
                </ui:Button>
            </Grid>
        </StackPanel>

        <!-- Updates list -->
        <ui:ListView Grid.Row="4" ItemsSource="{Binding Updates}" Margin="0,10,0,0"
                     VirtualizingPanel.IsVirtualizing="True"
                     Visibility="{Binding HasChecked, Converter={StaticResource VisibleWhenTrue}}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ui:ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Margin="10,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SubText}" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontSize="12" Foreground="{StaticResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ui:ListView.ItemTemplate>
        </ui:ListView>

        <!-- Recent history -->
        <StackPanel Grid.Row="5" Margin="0,10,0,0">
            <TextBlock Text="RECENTLY INSTALLED" Style="{StaticResource CyberSectionHeader}" Margin="0,0,0,6" />
            <ui:ListView ItemsSource="{Binding History}" MaxHeight="160"
                         VirtualizingPanel.IsVirtualizing="True" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ui:ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="1" Text="{Binding Result}" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" Margin="0,0,12,0" />
                            <TextBlock Grid.Column="2" Text="{Binding DateText}" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ui:ListView.ItemTemplate>
            </ui:ListView>
        </StackPanel>
    </Grid>
</Page>
