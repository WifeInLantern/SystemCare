<Page x:Class="SystemCare.Views.NetworkToolsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:NetworkToolsViewModel}"
      Title="Network"
      Loaded="OnPageLoaded" Unloaded="OnPageUnloaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Network Tools" Style="{StaticResource CyberPageTitle}" Margin="0,0,0,12" />

        <TabControl Grid.Row="1">
            <TabItem Header="Connections">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ui:Button Grid.Row="0" Content="Refresh" Padding="18,7" Command="{Binding RefreshConnectionsCommand}" HorizontalAlignment="Left">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowClockwise24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:ListView Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding Connections}"
                                 VirtualizingPanel.IsVirtualizing="True" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ui:ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Protocol}" FontSize="12" Opacity="0.6" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Local}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Remote}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding State}" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{Binding ProcessName}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>
                    <TextBlock Grid.Row="2" Text="{Binding ConnectionSummary}" FontSize="12" Opacity="0.65" Margin="0,8,0,0" />
                </Grid>
            </TabItem>

            <TabItem Header="Bandwidth">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Sort toggle -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Sort by" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,0" />
                        <RadioButton Content="Total" GroupName="netsort" IsChecked="{Binding IsSortCombined}" Margin="0,0,12,0" />
                        <RadioButton Content="Download" GroupName="netsort" IsChecked="{Binding IsSortDownload}" Margin="0,0,12,0" />
                        <RadioButton Content="Upload" GroupName="netsort" IsChecked="{Binding IsSortUpload}" />
                    </StackPanel>

                    <!-- Unavailable notice -->
                    <Border Grid.Row="1" Margin="0,10,0,0" Padding="12,10" CornerRadius="6"
                            Background="#1A1F1408" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                            Visibility="{Binding MonitoringUnavailable, Converter={StaticResource VisibleWhenTrue}}">
                        <TextBlock Text="{Binding MonitoringStatus}" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" />
                    </Border>

                    <!-- Column header + list -->
                    <Grid Grid.Row="2" Margin="0,10,0,0"
                          Visibility="{Binding MonitoringAvailable, Converter={StaticResource VisibleWhenTrue}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="8,0,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="118" />
                                <ColumnDefinition Width="118" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="170" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="Process" FontSize="11" Opacity="0.5" />
                            <TextBlock Grid.Column="2" Text="Download" FontSize="11" Opacity="0.5" />
                            <TextBlock Grid.Column="3" Text="Upload" FontSize="11" Opacity="0.5" />
                            <TextBlock Grid.Column="4" Text="Total ↓" FontSize="11" Opacity="0.5" />
                            <TextBlock Grid.Column="5" Text="Total ↑" FontSize="11" Opacity="0.5" />
                            <TextBlock Grid.Column="6" Text="Usage" FontSize="11" Opacity="0.5" />
                        </Grid>

                        <ui:ListView Grid.Row="1" ItemsSource="{Binding Processes}"
                                     VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ui:ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" CornerRadius="4" Margin="0,2" BorderThickness="1" BorderBrush="Transparent">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHigh}" Value="True">
                                                        <Setter Property="Background" Value="#26FF2A6D" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="118" />
                                                <ColumnDefinition Width="118" />
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="170" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center">
                                                <Image Source="{Binding Icon}" Width="18" Height="18" />
                                                <Ellipse Width="7" Height="7" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                         Fill="{Binding LevelBrush}" />
                                            </Grid>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,6,0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding PidText}" FontSize="10" Opacity="0.55" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="↓" FontSize="12" Foreground="{StaticResource SuccessBrush}" Margin="0,0,5,0" />
                                                <TextBlock Text="{Binding DownloadText}" FontSize="12" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="↑" FontSize="12" Foreground="{StaticResource WarningBrush}" Margin="0,0,5,0" />
                                                <TextBlock Text="{Binding UploadText}" FontSize="12" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="4" Text="{Binding TotalDownText}" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="5" Text="{Binding TotalUpText}" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />

                                            <Grid Grid.Column="6" VerticalAlignment="Center" Margin="4,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ProgressBar Grid.Column="0" Maximum="100" Height="6" Foreground="{Binding LevelBrush}"
                                                             helpers:Animations.SmoothValue="{Binding BarValue}" />
                                                <TextBlock Grid.Column="1" Text="{Binding PercentText}" FontSize="11" Opacity="0.75"
                                                           MinWidth="34" TextAlignment="Right" Margin="8,0,0,0" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ui:ListView.ItemTemplate>
                        </ui:ListView>
                    </Grid>

                    <TextBlock Grid.Row="3" Text="{Binding MonitoringStatus}" FontSize="12" Opacity="0.6" Margin="0,8,0,0"
                               Visibility="{Binding MonitoringAvailable, Converter={StaticResource VisibleWhenTrue}}" />
                </Grid>
            </TabItem>

            <TabItem Header="Tools">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Host or IP (e.g. 8.8.8.8)" Icon="{ui:SymbolIcon Globe24}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                            <ui:Button Content="Ping" Appearance="Primary" Padding="16,8" Command="{Binding PingCommand}" />
                            <ui:Button Content="Traceroute" Padding="14,8" Margin="6,0,0,0" Command="{Binding TracerouteCommand}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <ui:Button Content="Flush DNS cache" Padding="14,7" Command="{Binding FlushDnsCommand}" />
                        <ui:Button Content="Release / Renew IP" Padding="14,7" Margin="8,0,0,0" Command="{Binding RenewIpCommand}" />
                        <ui:Button Content="Cancel" Appearance="Danger" Padding="14,7" Margin="8,0,0,0"
                                   Command="{Binding CancelCommand}"
                                   Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
                    </StackPanel>
                    <Border Grid.Row="2" Margin="0,12,0,0" Background="{StaticResource ConsoleBackgroundBrush}" CornerRadius="6" BorderBrush="{StaticResource CyberStrokeBrush}" BorderThickness="1">
                        <TextBox x:Name="OutputBox" Style="{StaticResource CyberConsole}"
                                 Text="{Binding OutputText, Mode=OneWay}" TextChanged="OnOutputChanged" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
