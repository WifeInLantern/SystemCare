<Page x:Class="SystemCare.Views.GameBoosterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:GameBoosterViewModel}"
      Title="Game Booster"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,24" helpers:Animations.StaggerChildren="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Game Booster" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource TextBody}" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,0">
            <ui:Button Content="Activate Game Booster" Appearance="Primary" Padding="28,12" FontSize="15"
                       Command="{Binding ActivateCommand}"
                       IsEnabled="{Binding IsBusy, Converter={StaticResource Not}}"
                       Visibility="{Binding IsActive, Converter={StaticResource VisibleWhenFalse}}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Flash24" />
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Restore everything" Appearance="Success" Padding="28,12" FontSize="15"
                       Command="{Binding DeactivateCommand}"
                       IsEnabled="{Binding IsBusy, Converter={StaticResource Not}}"
                       Visibility="{Binding IsActive, Converter={StaticResource VisibleWhenTrue}}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowReset24" />
                </ui:Button.Icon>
            </ui:Button>
        </StackPanel>

        <CheckBox Grid.Row="2" Content="Silence notifications while boosting" Margin="0,14,0,0"
                  IsChecked="{Binding SilenceNotifications}" IsEnabled="{Binding IsActive, Converter={StaticResource Not}}" />

        <TextBlock Grid.Row="3" Text="Background apps to pause (well-known apps are pre-selected)"
                   Style="{StaticResource CyberSectionHeader}" Margin="0,18,0,8" />

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Apps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,6" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="{Binding RamText}" VerticalAlignment="Center" Style="{StaticResource TextCaption}" />
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
