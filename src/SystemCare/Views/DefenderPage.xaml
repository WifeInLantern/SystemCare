<Page x:Class="SystemCare.Views.DefenderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:DefenderViewModel}"
      Title="Defender"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <Grid Margin="24,12,24,16" helpers:Animations.StaggerChildren="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header + status -->
        <ui:Card Grid.Row="0" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Grid.Column="0" Symbol="{Binding StatusIcon}" FontSize="40" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Margin="16,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Microsoft Defender" Style="{StaticResource CyberPageTitle}" />
                    <TextBlock Text="{Binding Headline}" FontSize="13" Foreground="{StaticResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
                <ui:Button Grid.Column="2" Content="Refresh" Padding="14,7" VerticalAlignment="Center"
                           Command="{Binding RefreshCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowClockwise24" /></ui:Button.Icon>
                </ui:Button>
            </Grid>
        </ui:Card>

        <!-- Actions + details -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Protection details -->
            <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="Protection status" Style="{StaticResource CyberSectionHeader}" Margin="0,0,0,10" />
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Real-time protection" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding RealTimeText}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Tamper protection" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding TamperText}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Definitions" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding SignatureText}" FontWeight="SemiBold" TextAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Last quick scan" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding LastQuickScanText}" FontWeight="SemiBold" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Last full scan" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding LastFullScanText}" FontWeight="SemiBold" />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Actions -->
            <ui:Card Grid.Column="1" Margin="6,0,0,0" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="Actions" Style="{StaticResource CyberSectionHeader}" Margin="0,0,0,10" />
                    <ui:Button Content="Quick scan" Appearance="Primary" HorizontalAlignment="Stretch" Padding="14,9" Margin="0,0,0,8"
                               Command="{Binding QuickScanCommand}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="ShieldTask24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Full scan" HorizontalAlignment="Stretch" Padding="14,9" Margin="0,0,0,8"
                               Command="{Binding FullScanCommand}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="ShieldGlobe24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Update definitions" HorizontalAlignment="Stretch" Padding="14,9" Margin="0,0,0,8"
                               Command="{Binding UpdateSignaturesCommand}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowDownload24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Open Windows Security" HorizontalAlignment="Stretch" Padding="14,9"
                               Command="{Binding OpenSecurityCommand}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Open24" /></ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
            </ui:Card>
        </Grid>

        <!-- Live output console -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16"
                                     Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
                    <TextBlock Text="{Binding CurrentOperation}" Margin="8,0,0,0" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <ui:Button Grid.Column="1" Content="Cancel" Appearance="Danger" Padding="14,5"
                           Command="{Binding CancelCommand}"
                           Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
            </Grid>
            <Border Grid.Row="1" Background="{StaticResource ConsoleBackgroundBrush}" CornerRadius="6" BorderBrush="{StaticResource CyberStrokeBrush}" BorderThickness="1">
                <TextBox x:Name="OutputBox" Style="{StaticResource CyberConsole}"
                         Text="{Binding OutputText, Mode=OneWay}" TextChanged="OnOutputChanged" />
            </Border>
        </Grid>
    </Grid>
</Page>
