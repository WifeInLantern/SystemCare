<Page x:Class="SystemCare.Views.LargeFilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:LargeFilesViewModel}"
      Title="Large Files"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <Grid Margin="24,12,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Large &amp; Old Files" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Find the biggest files hogging space, see when each was last opened, and send the ones you don't need to the Recycle Bin."
                       Style="{StaticResource TextBody}" Margin="0,4,0,0" />
        </StackPanel>

        <ui:Card Grid.Row="1" Margin="0,14,0,0" Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" Text="{Binding SelectedFolder, UpdateSourceTrigger=PropertyChanged}"
                            VerticalContentAlignment="Center" MinHeight="34" PlaceholderText="Choose a folder to scan…" />
                <ui:Button Grid.Column="1" Content="Browse" Padding="12,7" Margin="8,0,0,0" Command="{Binding PickFolderCommand}" />
                <ComboBox Grid.Column="2" Margin="8,0,0,0" MinWidth="110" VerticalContentAlignment="Center"
                          ItemsSource="{Binding MinSizeOptions}" SelectedItem="{Binding MinSizeMb}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StringFormat='≥ {0} MB'}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ui:Button Grid.Column="3" Content="Scan" Appearance="Primary" Padding="16,7" Margin="8,0,0,0" Command="{Binding ScanCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Search24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Grid.Column="4" Content="Cancel" Appearance="Danger" Padding="12,7" Margin="8,0,0,0"
                           Command="{Binding ScanCancelCommand}"
                           Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            </Grid>
        </ui:Card>

        <Grid Grid.Row="2" Margin="2,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <controls:TaskProgress IsActive="{Binding IsBusy}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="8,0,0,0" Style="{StaticResource TextCaption}" />
            </StackPanel>
            <ui:Button Grid.Column="1" Content="Delete selected" Appearance="Danger" Padding="16,7"
                       Command="{Binding DeleteSelectedCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
            </ui:Button>
        </Grid>

        <Border Grid.Row="3" Margin="0,12,0,0" Background="{StaticResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" BorderBrush="{StaticResource CyberStrokeBrush}" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                <ItemsControl ItemsSource="{Binding Files}" Grid.IsSharedSizeScope="True">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <!-- v6: Auto + MinWidth instead of fixed 110px so long byte-strings
                                         and dates never clip at higher DPI / narrow windows. -->
                                    <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="LfSize" />
                                    <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="LfAge" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Margin="8,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource TextBodyStrong}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Directory}" Style="{StaticResource TextCaption}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding SizeText}" Style="{StaticResource TextMetricValue}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding LastAccessText}" Style="{StaticResource TextCaption}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
