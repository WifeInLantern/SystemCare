<Page x:Class="SystemCare.Views.RegistryCleanerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:RegistryCleanerViewModel}"
      Title="Registry Cleaner">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Registry Cleaner" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusText}" FontSize="13" Opacity="0.75" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Category chips -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Categories}" Margin="0,14,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ui:Card Margin="0,0,8,8" Padding="12,8" Width="250">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.6" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="{Binding FoundCount}" VerticalAlignment="Center"
                                       FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="6,0,0,0" />
                        </Grid>
                    </ui:Card>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,12">
            <ui:Button Content="Scan" Appearance="Primary" Padding="26,8"
                       Command="{Binding ScanCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource Not}}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Search24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Cancel" Padding="18,8" Margin="8,0,0,0"
                       Command="{Binding ScanCancelCommand}"
                       Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            <ui:Button Content="Clean selected" Appearance="Success" Padding="22,8" Margin="8,0,0,0"
                       Command="{Binding CleanCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Broom24" /></ui:Button.Icon>
            </ui:Button>
            <Separator Margin="12,0" />
            <ui:Button Content="Restore last backup" Padding="16,8" Command="{Binding RestoreLastBackupCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowUndo24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Open backups" Padding="16,8" Margin="8,0,0,0" Appearance="Secondary"
                       Command="{Binding OpenBackupsFolderCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="FolderOpen24" /></ui:Button.Icon>
            </ui:Button>
        </StackPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Issues}" VirtualizingPanel.IsVirtualizing="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,6" Padding="14,9">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayPath}" FontWeight="SemiBold" FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding CategoryName, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding Reason, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <ProgressBar IsIndeterminate="True" Height="4"
                         Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            <TextBlock Text="{Binding ProgressText}" FontSize="11" Opacity="0.55" Margin="0,6,0,0" TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</Page>
