<Window x:Class="SystemCare.Views.MiniMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SystemCare.Controls"
        Title="SystemCare Monitor"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" WindowStartupLocation="Manual"
        MouseLeftButtonDown="OnWindowMouseDown">
    <Border Width="232" CornerRadius="10" Background="{StaticResource CyberPanelBrush}"
            BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1" Padding="14,12"
            Effect="{StaticResource GlowMd}"
            TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}">
        <StackPanel>
            <!-- Header (drag handle) -->
            <Grid Margin="0,0,0,8">
                <TextBlock Text="SYSTEMCARE" FontFamily="{StaticResource DisplayFontFamily}"
                           FontSize="11" Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center" />
                <TextBlock x:Name="CloseGlyph" Text="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource TextFillColorSecondaryBrush}" Cursor="Hand"
                           Padding="6,2" MouseLeftButtonUp="OnCloseClick" ToolTip="Hide widget" />
            </Grid>

            <!-- CPU -->
            <Grid Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CPU" FontSize="11" Opacity="0.85" VerticalAlignment="Center" />
                <controls:SparklineChart Grid.Column="1" x:Name="CpuSpark" Height="24" Margin="6,0" Max="100" Accent="{StaticResource AccentColor}" />
                <TextBlock Grid.Column="2" x:Name="CpuValue" Text="—" FontWeight="SemiBold" MinWidth="46"
                           TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource NeonCyanBrush}" />
            </Grid>

            <!-- RAM -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="RAM" FontSize="11" Opacity="0.85" VerticalAlignment="Center" />
                <controls:SparklineChart Grid.Column="1" x:Name="RamSpark" Height="24" Margin="6,0" Max="100" Accent="{StaticResource SuccessColor}" />
                <TextBlock Grid.Column="2" x:Name="RamValue" Text="—" FontWeight="SemiBold" MinWidth="46"
                           TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource SuccessBrush}" />
            </Grid>

            <!-- Network -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="NET" FontSize="11" Opacity="0.85" VerticalAlignment="Center" />
                <controls:SparklineChart Grid.Column="1" x:Name="NetSpark" Height="24" Margin="6,0" Max="100" Accent="{StaticResource VioletColor}" />
                <TextBlock Grid.Column="2" x:Name="NetValue" Text="—" FontSize="12" MinWidth="46"
                           TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource NeonVioletBrush}" />
            </Grid>

            <!-- Temperature -->
            <Grid Margin="0,8,0,0" x:Name="TempRow">
                <TextBlock Text="TEMP" FontSize="11" Opacity="0.85" VerticalAlignment="Center" />
                <TextBlock x:Name="TempValue" Text="—" FontWeight="SemiBold" HorizontalAlignment="Right"
                           VerticalAlignment="Center" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
