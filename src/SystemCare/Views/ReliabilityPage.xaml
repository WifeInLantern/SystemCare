<Page x:Class="SystemCare.Views.ReliabilityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:ReliabilityViewModel}"
      Title="Reliability"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,12,24,24" helpers:Animations.StaggerChildren="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Reliability Center" Style="{StaticResource CyberPageTitle}" />
                <TextBlock Text="{Binding SummaryText}" FontSize="13" Opacity="0.75" Margin="0,4,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Actions -->
            <WrapPanel Grid.Row="1" Margin="0,14,0,0">
                <ui:Button Content="Refresh" Margin="0,0,8,8" Command="{Binding RefreshCommand}"
                           IsEnabled="{Binding IsLoading, Converter={StaticResource Not}}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowSync24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Create restore point" Margin="0,0,8,8" Command="{Binding CreateRestorePointCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="ShieldAdd24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Run system repair" Margin="0,0,8,8" Command="{Binding OpenSystemRepairCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Wrench24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Rescue Center" Margin="0,0,8,8" Command="{Binding OpenRescueCenterCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowUndo24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Event Viewer" Margin="0,0,8,8" Command="{Binding OpenEventViewerCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Open24" /></ui:Button.Icon>
                </ui:Button>
            </WrapPanel>

            <!-- Score + category counts -->
            <ui:Card Grid.Row="2" Margin="0,16,0,0" Padding="24,20"
                     Visibility="{Binding ReadOk, Converter={StaticResource VisibleWhenTrue}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <controls:HealthGauge Width="200" Height="200"
                                              Score="{Binding Score}" BandLabelOverride="{Binding Tier}" />
                        <TextBlock Text="STABILITY SCORE" FontSize="11" Opacity="0.6"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>

                    <ItemsControl Grid.Column="1" Margin="28,0,0,0" VerticalAlignment="Center"
                                  ItemsSource="{Binding Counts}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" helpers:Animations.StaggerChildren="True" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PanelInsetBrush}" CornerRadius="8"
                                        Margin="6" Padding="14,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="{Binding Icon}" FontSize="16" Opacity="0.8" />
                                            <TextBlock FontSize="22" Margin="8,0,0,0"
                                                       Style="{StaticResource CyberDisplayText}"
                                                       helpers:Animations.CountUpText="{Binding Count}"
                                                       helpers:Animations.CountUpFormat="0" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource TextCaption}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ui:Card>

            <!-- Issues list / empty / fallback -->
            <StackPanel Grid.Row="3" Margin="0,18,0,0">
                <TextBlock Text="Recent issues" Style="{StaticResource CyberSectionHeader}"
                           Visibility="{Binding HasIssues, Converter={StaticResource VisibleWhenTrue}}" />

                <ItemsControl ItemsSource="{Binding Events}" Margin="0,8,0,0"
                              Visibility="{Binding HasIssues, Converter={StaticResource VisibleWhenTrue}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Grid.Column="0" Symbol="{Binding Icon}"
                                                   Foreground="{Binding SeverityBrush}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Source}" FontSize="12" Opacity="0.6" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding TimeText}" FontSize="12" Opacity="0.6"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Crash correlation (2.14): what SystemCare changed before the latest serious event -->
                <StackPanel Visibility="{Binding HasCorrelation, Converter={StaticResource VisibleWhenTrue}}"
                            Margin="0,14,0,0">
                    <TextBlock Text="What changed beforehand" Style="{StaticResource CyberSectionHeader}" />
                    <TextBlock Text="{Binding CorrelationTitle}" Style="{StaticResource TextCaption}"
                               TextWrapping="Wrap" Margin="0,6,0,8" />
                    <ItemsControl ItemsSource="{Binding WhatChanged}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CyberListRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource CyberChipNeutral}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}" Style="{StaticResource ChipTextNeutral}" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Summary}" Margin="10,0,10,0"
                                                   VerticalAlignment="Center" Style="{StaticResource TextBody}"
                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                        <TextBlock Grid.Column="2" Text="{Binding TimeText}" Style="{StaticResource TextCaption}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- All clear -->
                <ui:Card Padding="20,28"
                         Visibility="{Binding ReadOk, Converter={StaticResource VisibleWhenTrue}}">
                    <ui:Card.Style>
                        <Style TargetType="ui:Card" BasedOn="{StaticResource {x:Type ui:Card}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasIssues}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Card.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="32" Foreground="{StaticResource SuccessBrush}"
                                       HorizontalAlignment="Center" />
                        <TextBlock Text="All clear — no recent reliability problems." Margin="0,10,0,0"
                                   Opacity="0.75" HorizontalAlignment="Center" />
                    </StackPanel>
                </ui:Card>

                <!-- Couldn't read the log -->
                <ui:Card Padding="20,28"
                         Visibility="{Binding ReadOk, Converter={StaticResource VisibleWhenFalse}}">
                    <StackPanel HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="32" Opacity="0.5" HorizontalAlignment="Center" />
                        <TextBlock Text="Couldn't read the Windows Event Log on this system."
                                   Margin="0,10,0,0" Opacity="0.7" HorizontalAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
