<Page x:Class="SystemCare.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
      Title="Dashboard"
      Loaded="OnPageLoaded" Unloaded="OnPageUnloaded">
    <Page.Resources>
        <converters:BytesToReadableConverter x:Key="Bytes" />
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,12,24,24">
        <StackPanel MaxWidth="1100">

            <!-- Health gauge + actions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:HealthGauge Grid.Column="0" Width="260" Height="260"
                                      Score="{Binding HealthScoreValue}" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="36,0,0,0">
                    <TextBlock Text="PC HEALTH" FontSize="30" Style="{StaticResource CyberDisplayText}" />
                    <TextBlock Text="{Binding LastScanSummary}" Margin="0,8,0,16"
                               TextWrapping="Wrap" Opacity="0.75" FontSize="14" />
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Scan now" Appearance="Primary" FontSize="15"
                                   helpers:Animations.NeonPulse="True"
                                   Padding="28,10" Command="{Binding ScanCommand}"
                                   IsEnabled="{Binding IsWorking, Converter={StaticResource Not}}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Search24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Fix all" Appearance="Success" FontSize="15"
                                   Padding="28,10" Margin="12,0,0,0"
                                   Command="{Binding FixAllCommand}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Wrench24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Free up RAM" FontSize="15"
                                   Padding="20,10" Margin="12,0,0,0"
                                   Command="{Binding OptimizeRamCommand}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Flash24" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                    <ProgressBar IsIndeterminate="True" Margin="0,16,40,0" Height="4"
                                 Visibility="{Binding IsWorking, Converter={StaticResource VisibleWhenTrue}}" />
                </StackPanel>
            </Grid>

            <!-- Quick actions (customizable in Settings) -->
            <StackPanel Visibility="{Binding AnyQuickAction, Converter={StaticResource VisibleWhenTrue}}">
                <TextBlock Text="QUICK ACTIONS" FontSize="16" Margin="0,28,0,12" Style="{StaticResource CyberSectionHeader}" />
                <WrapPanel Orientation="Horizontal">
                    <ui:Button Content="Scan &amp; Fix" Padding="18,9" Margin="0,0,8,8" Command="{Binding ScanCommand}"
                               Visibility="{Binding ShowScanFix, Converter={StaticResource VisibleWhenTrue}}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Wrench24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Free up RAM" Padding="18,9" Margin="0,0,8,8" Command="{Binding OptimizeRamCommand}"
                               Visibility="{Binding ShowFreeRam, Converter={StaticResource VisibleWhenTrue}}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Flash24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Flush DNS" Padding="18,9" Margin="0,0,8,8" Command="{Binding FlushDnsCommand}"
                               Visibility="{Binding ShowFlushDns, Converter={StaticResource VisibleWhenTrue}}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Globe24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Empty Recycle Bin" Padding="18,9" Margin="0,0,8,8" Command="{Binding EmptyRecycleBinCommand}"
                               Visibility="{Binding ShowEmptyBin, Converter={StaticResource VisibleWhenTrue}}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Create restore point" Padding="18,9" Margin="0,0,8,8" Command="{Binding CreateRestorePointCommand}"
                               Visibility="{Binding ShowRestorePoint, Converter={StaticResource VisibleWhenTrue}}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="ShieldAdd24" /></ui:Button.Icon>
                    </ui:Button>
                </WrapPanel>
            </StackPanel>

            <!-- Live stats -->
            <TextBlock Text="LIVE SYSTEM STATS" FontSize="16" Margin="0,28,0,12" Style="{StaticResource CyberSectionHeader}" />
            <UniformGrid Columns="2">
                <ui:Card Margin="0,0,8,0" Padding="20,16" helpers:Animations.HoverLift="True"
                         helpers:Animations.RevealOnLoad="True">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="20" />
                            <TextBlock Text="Processor" Margin="8,0,0,0" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Text="{Binding CpuText}" FontSize="32" FontWeight="Bold" Margin="0,8,0,4" />
                        <controls:SparklineChart Height="48" Margin="0,2,0,6"
                                                 Values="{Binding CpuHistory}" Max="100"
                                                 Accent="#00E5FF" />
                        <ProgressBar helpers:Animations.SmoothValue="{Binding CpuPercent}" Maximum="100" Height="6" />
                    </StackPanel>
                </ui:Card>
                <ui:Card Margin="8,0,0,0" Padding="20,16" helpers:Animations.HoverLift="True"
                         helpers:Animations.RevealOnLoad="True">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Ram20" FontSize="20" />
                            <TextBlock Text="Memory" Margin="8,0,0,0" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Text="{Binding RamText}" FontSize="26" FontWeight="Bold" Margin="0,8,0,4" />
                        <controls:SparklineChart Height="48" Margin="0,2,0,6"
                                                 Values="{Binding RamHistory}" Max="100"
                                                 Accent="#00FFA3" />
                        <ProgressBar helpers:Animations.SmoothValue="{Binding RamPercent}" Maximum="100" Height="6" />
                    </StackPanel>
                </ui:Card>
            </UniformGrid>

            <ItemsControl ItemsSource="{Binding Drives}" Margin="0,16,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,8,8" Padding="16,12" helpers:Animations.HoverLift="True"
                                 helpers:Animations.FadeInOnLoad="True">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="HardDrive20" FontSize="18" />
                                    <TextBlock Margin="8,0,0,0" FontWeight="SemiBold">
                                        <Run Text="{Binding Name, Mode=OneWay}" />
                                        <Run Text="{Binding Label, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Margin="0,8,0,4" Opacity="0.75" FontSize="12">
                                    <Run Text="{Binding FreeBytes, Mode=OneWay, Converter={StaticResource Bytes}}" />
                                    <Run Text="free of" />
                                    <Run Text="{Binding TotalBytes, Mode=OneWay, Converter={StaticResource Bytes}}" />
                                </TextBlock>
                                <ProgressBar Value="{Binding UsedPercent, Mode=OneWay}" Maximum="100" Height="5" />
                            </StackPanel>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Quick links -->
            <TextBlock Text="TOOLS" FontSize="16" Margin="0,20,0,12" Style="{StaticResource CyberSectionHeader}" />
            <UniformGrid Columns="5">
                <ui:CardAction Margin="0,0,8,0" Command="{Binding NavigateToCommand}" CommandParameter="Cleanup">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Broom24" />
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <TextBlock Text="Cleanup" FontWeight="SemiBold" />
                        <TextBlock Text="Remove junk files" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Margin="0,0,8,0" Command="{Binding NavigateToCommand}" CommandParameter="Startup">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Rocket24" />
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <TextBlock Text="Startup" FontWeight="SemiBold" />
                        <TextBlock Text="Boot faster" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Margin="0,0,8,0" Command="{Binding NavigateToCommand}" CommandParameter="Privacy">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Shield24" />
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <TextBlock Text="Privacy" FontWeight="SemiBold" />
                        <TextBlock Text="Clear traces" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Margin="0,0,8,0" Command="{Binding NavigateToCommand}" CommandParameter="Disk">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="DataPie24" />
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <TextBlock Text="Disk" FontWeight="SemiBold" />
                        <TextBlock Text="See space usage" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Command="{Binding NavigateToCommand}" CommandParameter="Duplicates">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Copy24" />
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <TextBlock Text="Duplicates" FontWeight="SemiBold" />
                        <TextBlock Text="Find extra copies" FontSize="11" Opacity="0.7" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardAction>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Page>
