<Page x:Class="SystemCare.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
      Title="Dashboard"
      Loaded="OnPageLoaded" Unloaded="OnPageUnloaded">
    <Page.Resources>
        <converters:BytesToReadableConverter x:Key="Bytes" />
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
        <converters:PercentToUsageBrushConverter x:Key="UsageBrush" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,12,24,24">
        <StackPanel MaxWidth="{StaticResource ContentMaxWidth}">

            <!-- Health gauge + actions -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <controls:HealthGauge Grid.Column="0" Width="260" Height="260"
                                      Score="{Binding HealthScoreValue}"
                                      helpers:Animations.RevealOnLoad="True"
                                      helpers:Animations.EntranceSpring="True" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="36,0,0,0">
                    <TextBlock Text="PC HEALTH" FontSize="30" Style="{StaticResource CyberDisplayText}" />
                    <TextBlock Text="{Binding LastScanSummary}" Margin="0,8,0,10"
                               Style="{StaticResource TextBody}" />
                    <!-- Explainable score (2.19): why the number is what it is; each chip jumps to its tool. -->
                    <WrapPanel Margin="0,0,0,14" Visibility="{Binding HasScoreInputs, Converter={StaticResource VisibleWhenTrue}}">
                        <WrapPanel.Resources>
                            <Style x:Key="ScoreChip" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary" />
                                <Setter Property="Padding" Value="10,4" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="Margin" Value="0,2,8,2" />
                                <Setter Property="BorderBrush" Value="{StaticResource CyberStrokeBrush}" />
                            </Style>
                        </WrapPanel.Resources>
                        <ui:Button Style="{StaticResource ScoreChip}" Content="{Binding JunkChipText}"
                                   ToolTipService.ToolTip="Open Junk Cleanup"
                                   Command="{Binding NavigateToCommand}" CommandParameter="Cleanup" />
                        <ui:Button Style="{StaticResource ScoreChip}" Content="{Binding StartupChipText}"
                                   ToolTipService.ToolTip="Open Startup Manager"
                                   Command="{Binding NavigateToCommand}" CommandParameter="Startup" />
                        <ui:Button Style="{StaticResource ScoreChip}" Content="{Binding RamChipText}"
                                   ToolTipService.ToolTip="Open Processes"
                                   Command="{Binding NavigateToCommand}" CommandParameter="Processes" />
                        <ui:Button Style="{StaticResource ScoreChip}" Content="{Binding SecurityChipText}"
                                   ToolTipService.ToolTip="Open Security Checkup"
                                   Command="{Binding NavigateToCommand}" CommandParameter="Security" />
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Scan now" Appearance="Primary" FontSize="15"
                                   helpers:Animations.NeonPulse="True"
                                   Padding="28,10" Command="{Binding ScanCommand}"
                                   IsEnabled="{Binding IsWorking, Converter={StaticResource Not}}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Search24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Fix all" Appearance="Success" FontSize="15"
                                   ToolTipService.ToolTip="Cleans the scanned junk and trims RAM, then re-scores. A restore point is offered first."
                                   Padding="28,10" Margin="12,0,0,0"
                                   Command="{Binding FixAllCommand}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Wrench24" />
                            </ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Free up RAM" FontSize="15"
                                   Padding="20,10" Margin="12,0,0,0"
                                   Command="{Binding OptimizeRamCommand}">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="Flash24" />
                            </ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                    <controls:TaskProgress IsActive="{Binding IsWorking}" Margin="0,16,40,0" />
                    <!-- Live temperature strip (2.16.x) — empty string collapses to nothing visible. -->
                    <TextBlock Text="{Binding TempSummary}" Style="{StaticResource TextCaption}" Margin="0,10,0,0" />
                </StackPanel>
            </Grid>

            <!-- Live stats -->
            <TextBlock Text="LIVE SYSTEM STATS" Margin="0,28,0,12" Style="{StaticResource CyberSectionHeader}"
                       helpers:Animations.FadeInOnLoad="True" helpers:Animations.RevealDelay="40" />
            <UniformGrid Columns="3">
                <ui:Card Margin="0,0,8,0" Padding="20,16" helpers:Animations.HoverLift="True"
                         helpers:Animations.RevealOnLoad="True" helpers:Animations.RevealDelay="80">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DeveloperBoard24" FontSize="20" />
                            <TextBlock Text="Processor" Margin="8,0,0,0" Style="{StaticResource TextBodyStrong}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource TextMetricHero}" Margin="0,8,0,4"
                                   helpers:Animations.CountUpText="{Binding CpuPercent}"
                                   helpers:Animations.CountUpFormat="0'%'" />
                        <controls:SparklineChart Height="48" Margin="0,2,0,6"
                                                 Values="{Binding CpuHistory}" Max="100"
                                                 Accent="{StaticResource AccentColor}" />
                        <ProgressBar helpers:Animations.SmoothValue="{Binding CpuPercent}" Maximum="100" Height="6" />
                    </StackPanel>
                </ui:Card>
                <ui:Card Margin="0,0,8,0" Padding="20,16" helpers:Animations.HoverLift="True"
                         helpers:Animations.RevealOnLoad="True" helpers:Animations.RevealDelay="150">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Ram20" FontSize="20" />
                            <TextBlock Text="Memory" Margin="8,0,0,0" Style="{StaticResource TextBodyStrong}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource TextMetricHero}" Margin="0,8,0,4"
                                   helpers:Animations.CountUpBytes="True"
                                   helpers:Animations.CountUpText="{Binding RamUsedBytes}"
                                   helpers:Animations.CountUpSuffix="{Binding RamTotalText}" />
                        <controls:SparklineChart Height="48" Margin="0,2,0,6"
                                                 Values="{Binding RamHistory}" Max="100"
                                                 Accent="{StaticResource SuccessColor}" />
                        <ProgressBar helpers:Animations.SmoothValue="{Binding RamPercent}" Maximum="100" Height="6" />
                    </StackPanel>
                </ui:Card>
            </UniformGrid>

            <ItemsControl ItemsSource="{Binding Drives}" Margin="0,16,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,8,8" Padding="16,12" helpers:Animations.HoverLift="True"
                                 helpers:Animations.FadeInOnLoad="True">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="HardDrive20" FontSize="18" />
                                    <TextBlock Margin="8,0,0,0" Style="{StaticResource TextBodyStrong}">
                                        <Run Text="{Binding Name, Mode=OneWay}" />
                                        <Run Text="{Binding Label, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Margin="0,8,0,4" Style="{StaticResource TextCaption}">
                                    <Run Text="{Binding FreeBytes, Mode=OneWay, Converter={StaticResource Bytes}}" />
                                    <Run Text="free of" />
                                    <Run Text="{Binding TotalBytes, Mode=OneWay, Converter={StaticResource Bytes}}" />
                                </TextBlock>
                                <ProgressBar Maximum="100" Height="5"
                                             helpers:Animations.SmoothValue="{Binding UsedPercent}"
                                             Foreground="{Binding UsedPercent, Converter={StaticResource UsageBrush}}" />
                                <!-- Storage Forecast (2.14): only shown when a meaningful downward trend exists. -->
                                <TextBlock Text="{Binding Forecast}" Margin="0,6,0,0" TextWrapping="Wrap"
                                           Foreground="{StaticResource WarningBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Forecast}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Quick links -->
            <TextBlock Text="TOOLS" Margin="0,20,0,12" Style="{StaticResource CyberSectionHeader}"
                       helpers:Animations.FadeInOnLoad="True" helpers:Animations.RevealDelay="180" />
            <UniformGrid Columns="5">
                <ui:CardAction Margin="0,0,8,0" Command="{Binding NavigateToCommand}" CommandParameter="Cleanup"
                               helpers:Animations.RevealOnLoad="True" helpers:Animations.RevealDelay="210">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Broom24" />
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <TextBlock Text="Cleanup" Style="{StaticResource TextBodyStrong}" />
                        <TextBlock Text="Remove junk files" Style="{StaticResource TextCaption}" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Margin="0,0,8,0" Command="{Binding NavigateToCommand}" CommandParameter="Startup"
                               helpers:Animations.RevealOnLoad="True" helpers:Animations.RevealDelay="260">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Rocket24" />
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <TextBlock Text="Startup" Style="{StaticResource TextBodyStrong}" />
                        <TextBlock Text="Boot faster" Style="{StaticResource TextCaption}" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Margin="0,0,8,0" Command="{Binding NavigateToCommand}" CommandParameter="Privacy"
                               helpers:Animations.RevealOnLoad="True" helpers:Animations.RevealDelay="310">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Shield24" />
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <TextBlock Text="Privacy" Style="{StaticResource TextBodyStrong}" />
                        <TextBlock Text="Clear traces" Style="{StaticResource TextCaption}" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Margin="0,0,8,0" Command="{Binding NavigateToCommand}" CommandParameter="Disk"
                               helpers:Animations.RevealOnLoad="True" helpers:Animations.RevealDelay="360">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="DataPie24" />
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <TextBlock Text="Disk" Style="{StaticResource TextBodyStrong}" />
                        <TextBlock Text="See space usage" Style="{StaticResource TextCaption}" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Command="{Binding NavigateToCommand}" CommandParameter="Duplicates"
                               helpers:Animations.RevealOnLoad="True" helpers:Animations.RevealDelay="410">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Copy24" />
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <TextBlock Text="Duplicates" Style="{StaticResource TextBodyStrong}" />
                        <TextBlock Text="Find extra copies" Style="{StaticResource TextCaption}" TextWrapping="Wrap" />
                    </StackPanel>
                </ui:CardAction>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</Page>