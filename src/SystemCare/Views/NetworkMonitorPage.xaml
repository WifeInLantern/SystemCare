<Page x:Class="SystemCare.Views.NetworkMonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:NetworkMonitorViewModel}"
      Title="Net Monitor"
      Loaded="OnPageLoaded" Unloaded="OnPageUnloaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <Grid Margin="24,12,24,24" helpers:Animations.StaggerChildren="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Net Monitor" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Which apps are using your internet, right now."
                       FontSize="13" Opacity="0.75" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Unavailable notice -->
        <Border Grid.Row="1" Margin="0,12,0,0" Padding="12,10" CornerRadius="6"
                Background="{StaticResource WarningSubtleBrush}" BorderBrush="{StaticResource WarningSubtleStroke}" BorderThickness="1"
                Visibility="{Binding MonitoringUnavailable, Converter={StaticResource VisibleWhenTrue}}">
            <TextBlock Text="{Binding MonitoringStatus}" Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" />
        </Border>

        <!-- Total throughput graph + session stats -->
        <ui:Card Grid.Row="2" Margin="0,14,0,0" Padding="18,14"
                 Visibility="{Binding MonitoringAvailable, Converter={StaticResource VisibleWhenTrue}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="TOTAL THROUGHPUT" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}"
                               Style="{StaticResource CyberSectionHeader}" />
                    <controls:SparklineChart Height="64" Margin="0,8,0,0"
                                             Values="{Binding ThroughputHistory}" Max="{Binding ThroughputMax}"
                                             Accent="{StaticResource AccentColor}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center" MinWidth="170">
                    <TextBlock Text="{Binding TotalRateText}" FontSize="26" Style="{StaticResource CyberDisplayText}" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="↓" FontSize="12" Foreground="{StaticResource SuccessBrush}" Margin="0,0,5,0" />
                        <TextBlock Text="{Binding SessionDownText}" FontSize="12" Margin="0,0,14,0" />
                        <TextBlock Text="↑" FontSize="12" Foreground="{StaticResource WarningBrush}" Margin="0,0,5,0" />
                        <TextBlock Text="{Binding SessionUpText}" FontSize="12" />
                    </StackPanel>
                    <TextBlock Text="{Binding SessionInfo}" FontSize="10" Foreground="{StaticResource TextFillColorTertiaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- Sort toggle -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,12,0,0"
                    Visibility="{Binding MonitoringAvailable, Converter={StaticResource VisibleWhenTrue}}">
            <TextBlock Text="Sort by" VerticalAlignment="Center" Foreground="{StaticResource TextFillColorTertiaryBrush}" Margin="0,0,10,0" />
            <RadioButton Content="Total" GroupName="netsort" IsChecked="{Binding IsSortCombined}" Margin="0,0,12,0" />
            <RadioButton Content="Download" GroupName="netsort" IsChecked="{Binding IsSortDownload}" Margin="0,0,12,0" />
            <RadioButton Content="Upload" GroupName="netsort" IsChecked="{Binding IsSortUpload}" />
        </StackPanel>

        <!-- Column header + list -->
        <Grid Grid.Row="4" Margin="0,10,0,0"
              Visibility="{Binding MonitoringAvailable, Converter={StaticResource VisibleWhenTrue}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="8,0,8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="118" />
                    <ColumnDefinition Width="118" />
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="170" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="Process" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" />
                <TextBlock Grid.Column="2" Text="Download" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" />
                <TextBlock Grid.Column="3" Text="Upload" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" />
                <TextBlock Grid.Column="4" Text="Total ↓" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" />
                <TextBlock Grid.Column="5" Text="Total ↑" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" />
                <TextBlock Grid.Column="6" Text="Usage" FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" />
            </Grid>

            <ui:ListView Grid.Row="1" ItemsSource="{Binding Processes}"
                         VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ui:ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,6" CornerRadius="4" Margin="0,2" BorderThickness="1" BorderBrush="Transparent">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHigh}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource DangerSubtleBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="118" />
                                    <ColumnDefinition Width="118" />
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="170" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center">
                                    <Image Source="{Binding Icon}" Width="18" Height="18" />
                                    <Ellipse Width="7" Height="7" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                             Fill="{Binding LevelBrush}" />
                                </Grid>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,6,0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding PidText}" FontSize="10" Foreground="{StaticResource TextFillColorTertiaryBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="↓" FontSize="12" Foreground="{StaticResource SuccessBrush}" Margin="0,0,5,0" />
                                    <TextBlock Text="{Binding DownloadText}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="↑" FontSize="12" Foreground="{StaticResource WarningBrush}" Margin="0,0,5,0" />
                                    <TextBlock Text="{Binding UploadText}" FontSize="12" />
                                </StackPanel>

                                <TextBlock Grid.Column="4" Text="{Binding TotalDownText}" FontSize="12" Foreground="{StaticResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="5" Text="{Binding TotalUpText}" FontSize="12" Foreground="{StaticResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />

                                <Grid Grid.Column="6" VerticalAlignment="Center" Margin="4,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Grid.Column="0" Maximum="100" Height="6" Foreground="{Binding LevelBrush}"
                                                 helpers:Animations.SmoothValue="{Binding BarValue}" />
                                    <TextBlock Grid.Column="1" Text="{Binding PercentText}" FontSize="11" Foreground="{StaticResource TextFillColorSecondaryBrush}"
                                               MinWidth="34" TextAlignment="Right" Margin="8,0,0,0" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ui:ListView.ItemTemplate>
            </ui:ListView>
        </Grid>

        <TextBlock Grid.Row="5" Text="{Binding MonitoringStatus}" FontSize="12" Foreground="{StaticResource TextFillColorTertiaryBrush}" Margin="0,8,0,0"
                   Visibility="{Binding MonitoringAvailable, Converter={StaticResource VisibleWhenTrue}}" />
    </Grid>
</Page>
