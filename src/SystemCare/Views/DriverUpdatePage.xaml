<Page x:Class="SystemCare.Views.DriverUpdatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:DriverUpdateViewModel}"
      Title="Driver Updater"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Driver Updater" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="Checks Windows Update for newer drivers and installs them safely. Coverage is what Microsoft distributes (most major vendors)."
                       FontSize="13" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,8">
            <ui:Button Content="Check for updates" Appearance="Primary" Padding="20,8"
                       Command="{Binding CheckForUpdatesCommand}"
                       IsEnabled="{Binding IsChecking, Converter={StaticResource Not}}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowSync24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Cancel" Padding="16,8" Margin="8,0,0,0"
                       Command="{Binding CheckForUpdatesCancelCommand}"
                       Visibility="{Binding IsChecking, Converter={StaticResource VisibleWhenTrue}}" />
            <ui:Button Content="Open Windows Update" Padding="16,8" Margin="8,0,0,0"
                       Command="{Binding OpenWindowsUpdateCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Settings24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Content="Device Manager" Padding="16,8" Margin="8,0,0,0"
                       Command="{Binding OpenDeviceManagerCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="DeveloperBoard24" /></ui:Button.Icon>
            </ui:Button>
        </StackPanel>

        <!-- Status + progress -->
        <StackPanel Grid.Row="2" Margin="0,0,0,4">
            <ProgressBar IsIndeterminate="True" Height="4"
                         Visibility="{Binding IsChecking, Converter={StaticResource VisibleWhenTrue}}" />
            <ProgressBar Maximum="100" Height="4" Value="{Binding InstallProgress}"
                         Visibility="{Binding IsInstalling, Converter={StaticResource VisibleWhenTrue}}" />
            <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.7" Margin="0,6,0,0"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <!-- Available updates -->
        <Grid Grid.Row="3" Margin="0,12,0,0"
              Visibility="{Binding HasChecked, Converter={StaticResource VisibleWhenTrue}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="AVAILABLE UPDATES" Style="{StaticResource CyberSectionHeader}"
                       VerticalAlignment="Center" />
            <ui:Button Grid.Column="1" Content="Install selected" Appearance="Primary" Padding="18,7"
                       Command="{Binding InstallSelectedCommand}"
                       IsEnabled="{Binding IsInstalling, Converter={StaticResource Not}}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowDownload24" /></ui:Button.Icon>
            </ui:Button>
        </Grid>

        <ui:ListView Grid.Row="4" ItemsSource="{Binding Updates}" MaxHeight="230" Margin="0,8,0,0"
                     Visibility="{Binding HasChecked, Converter={StaticResource VisibleWhenTrue}}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ui:ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis">
                                <Run Text="{Binding Manufacturer, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding DriverClass, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding DateText}" FontSize="12" Opacity="0.75"
                                   VerticalAlignment="Center" Margin="0,0,14,0" />
                        <TextBlock Grid.Column="3" Text="{Binding SizeText}" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ui:ListView.ItemTemplate>
        </ui:ListView>

        <!-- Installed devices inventory -->
        <Grid Grid.Row="5" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="INSTALLED DEVICES" Style="{StaticResource CyberSectionHeader}"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DeviceSummary}" FontSize="12" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <ui:Button Content="Rescan" Padding="14,6" Command="{Binding RefreshDevicesCommand}"
                               IsEnabled="{Binding IsLoadingDevices, Converter={StaticResource Not}}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowClockwise24" /></ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
            </Grid>

            <ui:ListView Grid.Row="1" ItemsSource="{Binding Devices}" Margin="0,8,0,0"
                         VirtualizingPanel.IsVirtualizing="True"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ui:ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="11" Opacity="0.55" TextTrimming="CharacterEllipsis">
                                    <Run Text="{Binding DeviceClass, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding Manufacturer, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <Border Grid.Column="1" Background="#33FF2A6D" CornerRadius="9" Padding="8,2" Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding HasProblem, Converter={StaticResource VisibleWhenTrue}}">
                                <TextBlock Text="{Binding ProblemText}" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource NeonMagentaBrush}" />
                            </Border>
                            <TextBlock Grid.Column="2" Text="{Binding VersionText}" FontSize="11" Opacity="0.7"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ui:ListView.ItemTemplate>
            </ui:ListView>
        </Grid>
    </Grid>
</Page>
