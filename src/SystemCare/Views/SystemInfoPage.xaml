<Page x:Class="SystemCare.Views.SystemInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance Type=vm:SystemInfoViewModel}"
      Title="System Info"
      Loaded="OnPageLoaded" Unloaded="OnPageUnloaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,12,24,24">
        <StackPanel MaxWidth="1100">
            <TextBlock Text="System Information" FontSize="24" FontWeight="SemiBold" />

            <!-- Live monitors -->
            <TextBlock Text="Live monitors" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,10" />
            <UniformGrid Columns="3">
                <ui:Card Margin="0,0,8,0" Padding="18,14" helpers:Animations.HoverLift="True">
                    <StackPanel>
                        <TextBlock Text="Processor" FontWeight="SemiBold" Opacity="0.85" />
                        <TextBlock Text="{Binding CpuText}" FontSize="26" FontWeight="Bold" Margin="0,4,0,6" />
                        <controls:SparklineChart Height="56" Values="{Binding CpuHistory}" Max="100" Accent="#00E5FF" />
                    </StackPanel>
                </ui:Card>
                <ui:Card Margin="8,0,8,0" Padding="18,14" helpers:Animations.HoverLift="True">
                    <StackPanel>
                        <TextBlock Text="Memory" FontWeight="SemiBold" Opacity="0.85" />
                        <TextBlock Text="{Binding RamText}" FontSize="26" FontWeight="Bold" Margin="0,4,0,6" />
                        <controls:SparklineChart Height="56" Values="{Binding RamHistory}" Max="100" Accent="#00FFA3" />
                    </StackPanel>
                </ui:Card>
                <ui:Card Margin="8,0,0,0" Padding="18,14" helpers:Animations.HoverLift="True">
                    <StackPanel>
                        <TextBlock Text="Network" FontWeight="SemiBold" Opacity="0.85" />
                        <TextBlock Text="{Binding NetText}" FontSize="15" FontWeight="Bold" Margin="0,8,0,6" />
                        <controls:SparklineChart Height="56" Values="{Binding NetHistory}" Max="{Binding NetMax}" Accent="#B14CFF" />
                    </StackPanel>
                </ui:Card>
            </UniformGrid>

            <!-- Hardware specs -->
            <TextBlock Text="Hardware" FontSize="16" FontWeight="SemiBold" Margin="0,22,0,10" />
            <ui:ProgressRing IsIndeterminate="True" Width="28" Height="28" HorizontalAlignment="Left"
                             Visibility="{Binding IsLoadingSpecs, Converter={StaticResource VisibleWhenTrue}}" />
            <ItemsControl ItemsSource="{Binding Specs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="16,12" helpers:Animations.HoverLift="True"
                                 helpers:Animations.FadeInOnLoad="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Grid.Column="0" Symbol="{Binding Icon}" FontSize="22" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Category}" Margin="12,0,0,0"
                                           VerticalAlignment="Center" Opacity="0.6" FontSize="12" />
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Detail}" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
