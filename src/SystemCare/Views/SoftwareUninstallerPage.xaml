<Page x:Class="SystemCare.Views.SoftwareUninstallerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:SoftwareUninstallerViewModel}"
      Title="Uninstaller"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <Grid Margin="24,12,24,24" helpers:Animations.StaggerChildren="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Software Uninstaller" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Remove installed programs. This runs each program's own uninstaller."
                       FontSize="13" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,14,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Content="Refresh" Command="{Binding RefreshCommand}" Padding="18,7">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowClockwise24" />
                </ui:Button.Icon>
            </ui:Button>
            <ui:TextBox Grid.Column="1" Margin="10,0,0,0" PlaceholderText="Search by name or publisher…"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Icon="{ui:SymbolIcon Search24}" />
        </Grid>

        <ui:ListView Grid.Row="2" ItemsSource="{Binding Items}"
                     VirtualizingPanel.IsVirtualizing="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ui:ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="11" Foreground="{StaticResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis">
                                <Run Text="{Binding Publisher, Mode=OneWay}" /><Run Text="  ·  v" /><Run Text="{Binding Version, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding InstallDateText}" VerticalAlignment="Center"
                                   FontSize="12" Opacity="0.6" />
                        <TextBlock Grid.Column="2" Text="{Binding SizeText}" VerticalAlignment="Center"
                                   FontSize="12" Opacity="0.8" HorizontalAlignment="Right" Margin="0,0,8,0" />
                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <ui:Button Padding="8,6" Appearance="Secondary" ToolTip="Open install folder"
                                       Command="{Binding DataContext.OpenLocationCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                       CommandParameter="{Binding}">
                                <ui:Button.Icon>
                                    <ui:SymbolIcon Symbol="FolderOpen24" />
                                </ui:Button.Icon>
                            </ui:Button>
                            <ui:Button Padding="12,6" Margin="6,0,0,0" Appearance="Danger" Content="Uninstall"
                                       Command="{Binding DataContext.UninstallCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                       CommandParameter="{Binding}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ui:ListView.ItemTemplate>
        </ui:ListView>

        <StackPanel Grid.Row="3" Margin="0,10,0,0">
            <controls:TaskProgress IsActive="{Binding IsBusy}" />
            <TextBlock Text="{Binding SummaryText}" Style="{StaticResource TextCaption}" Margin="0,6,0,0" />
        </StackPanel>
    </Grid>
</Page>
