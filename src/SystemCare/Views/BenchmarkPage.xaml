<Page x:Class="SystemCare.Views.BenchmarkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:BenchmarkViewModel}"
      Title="Benchmark"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenFalse" Invert="True" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,12,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="PC Benchmark" Style="{StaticResource CyberPageTitle}" />
                <TextBlock Text="{Binding CurrentPhase}" FontSize="13" Opacity="0.75" Margin="0,4,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Run / Cancel + progress -->
            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="Run benchmark" Appearance="Primary" Padding="32,12" FontSize="15"
                               Command="{Binding RunCommand}"
                               Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenFalse}}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Gauge24" />
                        </ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Cancel" Appearance="Danger" Padding="32,12" FontSize="15"
                               Command="{Binding CancelCommand}"
                               Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Stop24" />
                        </ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
                <ProgressBar Margin="0,14,0,0" Height="6" Maximum="100" Value="{Binding Progress}"
                             Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
            </StackPanel>

            <!-- Score gauge + headline points -->
            <ui:Card Grid.Row="2" Margin="0,20,0,0" Padding="24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <controls:HealthGauge Grid.Column="0" Width="220" Height="220"
                                          Score="{Binding OverallScore}" BandLabelOverride="{Binding Tier}" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="36,0,0,0">
                        <TextBlock Text="NIGHT CITY SCORE" FontSize="13" Opacity="0.7"
                                   Style="{StaticResource CyberSectionHeader}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                    Visibility="{Binding HasResult, Converter={StaticResource VisibleWhenTrue}}">
                            <TextBlock Text="{Binding Points, StringFormat='{}{0:N0}'}" FontSize="48"
                                       Style="{StaticResource CyberDisplayText}" />
                            <TextBlock Text="pts" FontSize="18" Opacity="0.6" VerticalAlignment="Bottom" Margin="8,0,0,12" />
                        </StackPanel>
                        <TextBlock Text="Run the benchmark to see your score."
                                   FontSize="15" Opacity="0.6" Margin="0,6,0,0"
                                   Visibility="{Binding HasResult, Converter={StaticResource VisibleWhenFalse}}" />
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Sub-test cards -->
            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Margin="0,0,6,0" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DeveloperBoard24" />
                            <TextBlock Text="CPU" FontWeight="SemiBold" FontSize="15" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding CpuText}" FontSize="20" Margin="0,8,0,0" Style="{StaticResource CyberDisplayText}" />
                        <TextBlock Text="multi-thread compute" FontSize="11" Opacity="0.6" />
                        <ProgressBar Height="6" Maximum="100" Value="{Binding CpuScore}" Margin="0,8,0,0" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="1" Margin="6,0,6,0" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Ram20" />
                            <TextBlock Text="Memory" FontWeight="SemiBold" FontSize="15" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding RamText}" FontSize="20" Margin="0,8,0,0" Style="{StaticResource CyberDisplayText}" />
                        <TextBlock Text="copy bandwidth" FontSize="11" Opacity="0.6" />
                        <ProgressBar Height="6" Maximum="100" Value="{Binding RamScore}" Margin="0,8,0,0" />
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="2" Margin="6,0,0,0" Padding="16,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="HardDrive24" />
                            <TextBlock Text="Disk" FontWeight="SemiBold" FontSize="15" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding DiskText}" FontSize="20" Margin="0,8,0,0" Style="{StaticResource CyberDisplayText}" />
                        <TextBlock Text="sequential write" FontSize="11" Opacity="0.6" />
                        <ProgressBar Height="6" Maximum="100" Value="{Binding DiskScore}" Margin="0,8,0,0" />
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- Trend + disclaimer -->
            <StackPanel Grid.Row="4" Margin="0,18,0,0">
                <TextBlock Text="Score history" Style="{StaticResource CyberSectionHeader}"
                           Visibility="{Binding HasTrend, Converter={StaticResource VisibleWhenTrue}}" />
                <ui:Card Padding="16,14" Margin="0,8,0,0"
                         Visibility="{Binding HasTrend, Converter={StaticResource VisibleWhenTrue}}">
                    <controls:SparklineChart Height="64" Values="{Binding Trend}" Max="{Binding TrendMax}" Accent="#00E5FF" />
                </ui:Card>
                <TextBlock Margin="0,12,0,0" FontSize="11" Opacity="0.55" TextWrapping="Wrap"
                           Text="A quick local benchmark — results vary with background load and thermal state. Scores are relative, not industry-standard figures. Nothing leaves your PC." />
            </StackPanel>

            <!-- Raw metrics of every stored run -->
            <ui:CardExpander Grid.Row="5" Margin="0,12,0,0" IsExpanded="False"
                             Visibility="{Binding HasRuns, Converter={StaticResource VisibleWhenTrue}}">
                <ui:CardExpander.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DataUsage24" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="Run details" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </ui:CardExpander.Header>
                <StackPanel>
                    <Grid Margin="14,0,14,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="WHEN" FontSize="11" Opacity="0.6" />
                        <TextBlock Grid.Column="1" Text="SCORE" FontSize="11" Opacity="0.6" />
                        <TextBlock Grid.Column="2" Text="CPU" FontSize="11" Opacity="0.6" />
                        <TextBlock Grid.Column="3" Text="MEMORY" FontSize="11" Opacity="0.6" />
                        <TextBlock Grid.Column="4" Text="DISK" FontSize="11" Opacity="0.6" />
                        <TextBlock Grid.Column="5" Text="SUB-SCORES" FontSize="11" Opacity="0.6" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding RunHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,8" Margin="0,4,0,0" CornerRadius="6"
                                        Background="{StaticResource PanelInsetBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="1.4*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="2*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding When}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding PointsText}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource NeonCyanBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding CpuRaw}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding RamRaw}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="{Binding DiskRaw}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="5" Text="{Binding SubScores}" FontSize="12" Opacity="0.75" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ui:CardExpander>
        </Grid>
    </ScrollViewer>
</Page>
