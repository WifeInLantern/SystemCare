<Page x:Class="SystemCare.Views.BrowserCleanupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:BrowserCleanupViewModel}"
      Title="Browser Cleanup"
      Loaded="OnPageLoaded">

    <Grid Margin="24,12,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Browser Cleanup" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Reclaim space and clear traces from your installed browsers. Close the browser first so its locked files can be removed."
                       FontSize="13" Opacity="0.78" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <ui:Card Grid.Row="1" Margin="0,14,0,0" Padding="16,12">
            <!-- WrapPanel so the options + buttons wrap to a new line instead of clipping at narrow widths. -->
            <WrapPanel>
                <TextBlock Text="Clear:" VerticalAlignment="Center" Foreground="{StaticResource TextFillColorSecondaryBrush}" Margin="0,4,12,4" />
                <CheckBox Content="Cache" IsChecked="{Binding ClearCache}" VerticalAlignment="Center" Margin="0,4,16,4" />
                <CheckBox Content="Cookies" IsChecked="{Binding ClearCookies}" VerticalAlignment="Center" Margin="0,4,16,4" />
                <CheckBox Content="History" IsChecked="{Binding ClearHistory}" VerticalAlignment="Center" Margin="0,4,16,4" />
                <ui:Button Content="Clean selected" Appearance="Primary" Padding="16,7" Margin="8,4,0,4" Command="{Binding CleanCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Broom24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Rescan" Padding="14,7" Margin="8,4,0,4" Command="{Binding ScanCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowClockwise24" /></ui:Button.Icon>
                </ui:Button>
            </WrapPanel>
        </ui:Card>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="2,12,0,0">
            <controls:TaskProgress IsActive="{Binding IsBusy}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <ItemsControl ItemsSource="{Binding Browsers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="16,12" helpers:Animations.FadeInOnLoad="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                           Margin="10,0,0,0" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding CacheText}" VerticalAlignment="Center" Foreground="{StaticResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
