<Page x:Class="SystemCare.Views.RepairToolkitPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:RepairToolkitViewModel}"
      Title="Repair Toolkit"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <ui:Card Grid.Row="0" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Repair Toolkit" Style="{StaticResource CyberPageTitle}" />
                    <TextBlock Text="Run SFC, DISM, and CHKDSK to find and fix corrupt system files and disk errors." FontSize="13" Opacity="0.8" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
                <ui:Button Grid.Column="1" Content="Run all (SFC → DISM → CHKDSK)" Appearance="Primary" Padding="16,9"
                           Command="{Binding RunAllCommand}">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Flash24" /></ui:Button.Icon>
                </ui:Button>
            </Grid>
        </ui:Card>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Repair steps" Style="{StaticResource CyberSectionHeader}" Margin="0,0,0,8" />

                <ui:Card Margin="0,0,0,8" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="System File Checker (SFC)" FontWeight="SemiBold" />
                            <TextBlock Text="Scans and repairs corrupted Windows system files." FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SfcStatus}" FontSize="12" Opacity="0.85" Margin="0,4,0,0" />
                        </StackPanel>
                        <ui:Button Grid.Column="1" Content="Scan system files" Padding="14,7" VerticalAlignment="Center"
                                   Command="{Binding RunSfcCommand}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentSearch24" /></ui:Button.Icon>
                        </ui:Button>
                    </Grid>
                </ui:Card>

                <ui:Card Margin="0,0,0,8" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Deployment Image Servicing (DISM)" FontWeight="SemiBold" />
                            <TextBlock Text="Repairs the underlying Windows image that SFC relies on. Can take 10–20+ minutes." FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DismStatus}" FontSize="12" Opacity="0.85" Margin="0,4,0,0" />
                        </StackPanel>
                        <ui:Button Grid.Column="1" Content="Repair Windows image" Padding="14,7" VerticalAlignment="Center"
                                   Command="{Binding RunDismCommand}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Wrench24" /></ui:Button.Icon>
                        </ui:Button>
                    </Grid>
                </ui:Card>

                <ui:Card Margin="0,0,0,8" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <TextBlock Text="Check Disk (CHKDSK) — repair mode" FontWeight="SemiBold" />
                            <TextBlock Text="Finds and fixes file-system and bad-sector errors. The system drive can't be locked live, so this is usually scheduled for the next restart." FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ChkdskStatus}" FontSize="12" Opacity="0.85" Margin="0,4,0,0" />
                        </StackPanel>
                        <ComboBox Grid.Column="1" MinWidth="80" VerticalAlignment="Center" Margin="0,0,10,0"
                                  ItemsSource="{Binding AvailableDrives}" SelectedItem="{Binding SelectedDrive}" />
                        <ui:Button Grid.Column="2" Content="Check drive" Padding="14,7" VerticalAlignment="Center"
                                   Command="{Binding RunChkdskCommand}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="ErrorCircle24" /></ui:Button.Icon>
                        </ui:Button>
                    </Grid>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- Live output console -->
        <Grid Grid.Row="2" Margin="0,12,0,0" Height="200">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16"
                                     Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
                    <TextBlock Text="{Binding CurrentOperation}" Margin="8,0,0,0" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <ui:Button Grid.Column="1" Content="Cancel" Appearance="Danger" Padding="14,5"
                           Command="{Binding CancelCommand}"
                           Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
            </Grid>
            <Border Grid.Row="1" Background="{StaticResource ConsoleBackgroundBrush}" CornerRadius="6" BorderBrush="{StaticResource CyberStrokeBrush}" BorderThickness="1">
                <TextBox x:Name="OutputBox" Style="{StaticResource CyberConsole}"
                         Text="{Binding OutputText, Mode=OneWay}" TextChanged="OnOutputChanged" />
            </Border>
        </Grid>
    </Grid>
</Page>
