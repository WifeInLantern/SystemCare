<Page x:Class="SystemCare.Views.AppCachesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:AppCachesViewModel}"
      Title="App Caches"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
    </Page.Resources>

    <Grid Margin="24,12,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="App Cache Cleaner" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Purge regenerable caches from apps and developer tools — often multi-GB. Apps rebuild these automatically; files written in the last 24 hours are always left alone."
                       Style="{StaticResource TextBody}" Margin="0,4,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="2,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Content="Scan" Appearance="Primary" Padding="16,7" Command="{Binding ScanCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Search24" /></ui:Button.Icon>
            </ui:Button>
            <ui:Button Grid.Column="1" Content="Cancel" Appearance="Danger" Padding="12,7" Margin="8,0,0,0"
                       Command="{Binding ScanCancelCommand}"
                       Visibility="{Binding IsBusy, Converter={StaticResource VisibleWhenTrue}}" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0,0,0">
                <controls:TaskProgress IsActive="{Binding IsBusy}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="8,0,8,0"
                           Style="{StaticResource TextCaption}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <ui:Button Grid.Column="3" Content="Clean selected" Appearance="Primary" Padding="16,7"
                       Command="{Binding CleanSelectedCommand}">
                <ui:Button.Icon><ui:SymbolIcon Symbol="Broom24" /></ui:Button.Icon>
            </ui:Button>
        </Grid>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Margin="0,0,0,8" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" MinWidth="88" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Margin="8,0,8,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource TextBodyStrong}" />
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource TextCaption}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Grid.Column="2" Style="{StaticResource CyberChipNeutral}" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding Group}" Style="{StaticResource ChipTextNeutral}" />
                                </Border>
                                <TextBlock Grid.Column="3" Text="{Binding SizeText}" Style="{StaticResource TextMetricValue}" VerticalAlignment="Center" />
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
