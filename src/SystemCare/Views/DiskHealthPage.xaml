<Page x:Class="SystemCare.Views.DiskHealthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:SystemCare.Controls"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:DiskHealthViewModel}"
      Title="Disk Health"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:InverseBoolConverter x:Key="Not" />
        <converters:PercentToUsageBrushConverter x:Key="UsageBrush" />
    </Page.Resources>

    <Grid Margin="24,12,24,16" helpers:Animations.StaggerChildren="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: overall score + summary + primary actions -->
        <ui:Card Grid.Row="0" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <controls:HealthGauge Grid.Column="0" Score="{Binding OverallScore}" Width="108" Height="108" />
                <StackPanel Grid.Column="1" Margin="18,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="Disk Health" Style="{StaticResource CyberPageTitle}" />
                    <TextBlock Text="{Binding SummaryText}" FontSize="13" Opacity="0.8" Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <ui:Button Content="Optimize all drives" Appearance="Primary" Padding="16,9" HorizontalAlignment="Stretch"
                               Command="{Binding MaintainAllCommand}">
                        <ui:Button.Icon><ui:SymbolIcon Symbol="Flash24" /></ui:Button.Icon>
                    </ui:Button>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Content="Restore point" Padding="12,7" Command="{Binding CreateRestorePointCommand}"
                                   IsEnabled="{Binding IsRunning, Converter={StaticResource Not}}" />
                        <ui:Button Content="Refresh" Padding="12,7" Margin="8,0,0,0" Appearance="Secondary"
                                   Command="{Binding RefreshCommand}"
                                   IsEnabled="{Binding IsRunning, Converter={StaticResource Not}}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ui:Card>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
            <StackPanel>
                <ui:ProgressRing IsIndeterminate="True" Width="28" Height="28" HorizontalAlignment="Left" Margin="0,4,0,0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource VisibleWhenTrue}}" />

                <!-- Alerts -->
                <ItemsControl ItemsSource="{Binding Alerts}" Margin="0,0,0,4"
                              Visibility="{Binding HasAlerts, Converter={StaticResource VisibleWhenTrue}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CyberGlassPanelRaised}" Margin="0,0,0,8"
                                    helpers:Animations.FadeInOnLoad="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Grid.Column="0" Symbol="{Binding Icon}" FontSize="20" VerticalAlignment="Center"
                                                   Foreground="{Binding Brush}" Margin="0,0,12,0" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{Binding Brush}" />
                                        <TextBlock Text="{Binding Detail}" FontSize="12" Opacity="0.78" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="2" Content="{Binding ActionLabel}" Padding="12,6" Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding HasAction, Converter={StaticResource VisibleWhenTrue}}"
                                               Command="{Binding DataContext.AlertActionCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Physical drives -->
                <TextBlock Text="Drives" Style="{StaticResource CyberSectionHeader}" Margin="0,10,0,8" />
                <ItemsControl ItemsSource="{Binding DiskCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Width="340" Margin="0,0,10,10" Padding="14,12"
                                     helpers:Animations.HoverLift="True" helpers:Animations.FadeInOnLoad="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <controls:HealthGauge Grid.Column="0" Score="{Binding Score}" Width="92" Height="92"
                                                          VerticalAlignment="Top" />
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="{Binding MediaIcon}" FontSize="16" VerticalAlignment="Center"
                                                           Foreground="{StaticResource NeonCyanBrush}" Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock FontSize="11" Opacity="0.6" Margin="0,2,0,0">
                                            <Run Text="{Binding Media, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding SizeText, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding HealthText, Mode=OneWay}" />
                                        </TextBlock>
                                        <WrapPanel Margin="0,8,0,0">
                                            <Border Style="{StaticResource CyberChip}" Margin="0,0,6,6"
                                                    Visibility="{Binding HasTemp, Converter={StaticResource VisibleWhenTrue}}">
                                                <TextBlock Text="{Binding TempText}" FontSize="11" />
                                            </Border>
                                            <Border Style="{StaticResource CyberChip}" Margin="0,0,6,6"
                                                    Visibility="{Binding HasWear, Converter={StaticResource VisibleWhenTrue}}">
                                                <TextBlock Text="{Binding WearText}" FontSize="11" />
                                            </Border>
                                            <Border Style="{StaticResource CyberChip}" Margin="0,0,6,6"
                                                    Visibility="{Binding HasHours, Converter={StaticResource VisibleWhenTrue}}">
                                                <TextBlock Text="{Binding HoursText}" FontSize="11" />
                                            </Border>
                                            <Border Style="{StaticResource CyberChipDanger}" Margin="0,0,6,6"
                                                    Visibility="{Binding HasErrors, Converter={StaticResource VisibleWhenTrue}}">
                                                <TextBlock Text="{Binding ErrorsText}" Style="{StaticResource ChipTextDanger}" />
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Volumes -->
                <TextBlock Text="Volumes" Style="{StaticResource CyberSectionHeader}" Margin="0,8,0,8" />
                <ItemsControl ItemsSource="{Binding Volumes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold">
                                            <Run Text="{Binding Letter, Mode=OneWay}" /><Run Text=" " /><Run Text="{Binding Label, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding FreeText}" FontSize="11" Opacity="0.6" />
                                    </StackPanel>
                                    <ProgressBar Grid.Column="1" Value="{Binding UsedPercent, Mode=OneWay}" Maximum="100"
                                                 Height="6" VerticalAlignment="Center" Margin="0,0,12,0"
                                                 Foreground="{Binding UsedPercent, Converter={StaticResource UsageBrush}}" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <ui:Button Content="Check for errors" Padding="12,6"
                                                   Command="{Binding CheckErrorsCommand}"
                                                   IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource Not}}" />
                                        <ui:Button Content="Optimize" Padding="12,6" Margin="6,0,0,0" Appearance="Secondary"
                                                   Command="{Binding OptimizeCommand}"
                                                   IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource Not}}" />
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Free up space (deep-links to existing tools) -->
                <TextBlock Text="Free up space" Style="{StaticResource CyberSectionHeader}" Margin="0,8,0,8" />
                <UniformGrid Columns="3">
                    <ui:CardAction Margin="0,0,8,0" Command="{Binding NavigateCommand}" CommandParameter="Cleanup">
                        <ui:CardAction.Icon><ui:SymbolIcon Symbol="Broom24" /></ui:CardAction.Icon>
                        <StackPanel>
                            <TextBlock Text="Clean junk &amp; cache" FontWeight="SemiBold" />
                            <TextBlock Text="Remove temporary and leftover files" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                        </StackPanel>
                    </ui:CardAction>
                    <ui:CardAction Margin="8,0,8,0" Command="{Binding NavigateCommand}" CommandParameter="Duplicates">
                        <ui:CardAction.Icon><ui:SymbolIcon Symbol="DocumentCopy24" /></ui:CardAction.Icon>
                        <StackPanel>
                            <TextBlock Text="Find duplicates" FontWeight="SemiBold" />
                            <TextBlock Text="Reclaim space from repeated files" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                        </StackPanel>
                    </ui:CardAction>
                    <ui:CardAction Margin="8,0,0,0" Command="{Binding NavigateCommand}" CommandParameter="Disk">
                        <ui:CardAction.Icon><ui:SymbolIcon Symbol="DataPie24" /></ui:CardAction.Icon>
                        <StackPanel>
                            <TextBlock Text="Find large files" FontWeight="SemiBold" />
                            <TextBlock Text="See what's using the most space" FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                        </StackPanel>
                    </ui:CardAction>
                </UniformGrid>

                <!-- Advanced repair -->
                <ui:CardExpander Margin="0,12,0,0" IsExpanded="False">
                    <ui:CardExpander.Header>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Wrench24" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Advanced repair (system files)" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </ui:CardExpander.Header>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ui:Button Content="Scan system files (SFC)" Padding="16,8" Command="{Binding RunSfcCommand}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentSearch24" /></ui:Button.Icon>
                        </ui:Button>
                        <ui:Button Content="Repair image (DISM)" Padding="16,8" Margin="8,0,0,0" Command="{Binding RunDismCommand}">
                            <ui:Button.Icon><ui:SymbolIcon Symbol="Wrench24" /></ui:Button.Icon>
                        </ui:Button>
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </ScrollViewer>

        <!-- Live output console -->
        <Grid Grid.Row="2" Margin="0,12,0,0" Height="200">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16"
                                     Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
                    <TextBlock Text="{Binding CurrentOperation}" Margin="8,0,0,0" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <ui:Button Grid.Column="1" Content="Cancel" Appearance="Danger" Padding="14,5"
                           Command="{Binding CancelCommand}"
                           Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
            </Grid>
            <Border Grid.Row="1" Background="{StaticResource ConsoleBackgroundBrush}" CornerRadius="6" BorderBrush="{StaticResource CyberStrokeBrush}" BorderThickness="1">
                <TextBox x:Name="OutputBox" Style="{StaticResource CyberConsole}"
                         Text="{Binding OutputText, Mode=OneWay}" TextChanged="OnOutputChanged" />
            </Border>
        </Grid>
    </Grid>
</Page>
