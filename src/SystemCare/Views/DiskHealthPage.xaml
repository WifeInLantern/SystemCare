<Page x:Class="SystemCare.Views.DiskHealthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:converters="clr-namespace:SystemCare.Converters"
      xmlns:helpers="clr-namespace:SystemCare.Helpers"
      xmlns:vm="clr-namespace:SystemCare.ViewModels"
      mc:Ignorable="d"
      TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}"
      d:DataContext="{d:DesignInstance Type=vm:DiskHealthViewModel}"
      Title="Disk Health"
      Loaded="OnPageLoaded">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="VisibleWhenTrue" />
        <converters:BytesToReadableConverter x:Key="Bytes" />
        <converters:InverseBoolConverter x:Key="Not" />
    </Page.Resources>

    <Grid Margin="24,12,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Disk Health &amp; Maintenance" Style="{StaticResource CyberPageTitle}" />
            <TextBlock Text="Check drives for errors, optimize them, and repair Windows system files."
                       FontSize="13" Opacity="0.7" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Disabled" MaxHeight="320">
            <StackPanel>
                <!-- Physical disk SMART -->
                <TextBlock Text="Drive health (SMART)" FontSize="15" FontWeight="SemiBold" Margin="0,16,0,8" />
                <ItemsControl ItemsSource="{Binding Disks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,8,8" Padding="14,10" Width="270" helpers:Animations.FadeInOnLoad="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ui:SymbolIcon Grid.Column="0" Symbol="HardDrive24" FontSize="22" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11" Opacity="0.6">
                                            <Run Text="{Binding MediaType, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding SizeBytes, Mode=OneWay, Converter={StaticResource Bytes}}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="2" CornerRadius="10" Padding="8,3" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#33445566" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HealthText}" Value="Healthy">
                                                        <Setter Property="Background" Value="#3300FFA3" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HealthText}" Value="Warning">
                                                        <Setter Property="Background" Value="#33FFD300" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HealthText}" Value="Failing">
                                                        <Setter Property="Background" Value="#33FF2A6D" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding HealthText}" FontSize="11" FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Volumes -->
                <TextBlock Text="Volumes" FontSize="15" FontWeight="SemiBold" Margin="0,8,0,8" />
                <ItemsControl ItemsSource="{Binding Volumes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Card Margin="0,0,0,6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold">
                                            <Run Text="{Binding Letter, Mode=OneWay}" /><Run Text=" " /><Run Text="{Binding Label, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding FreeText}" FontSize="11" Opacity="0.6" />
                                    </StackPanel>
                                    <ProgressBar Grid.Column="1" Value="{Binding UsedPercent, Mode=OneWay}" Maximum="100"
                                                 Height="6" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <ui:Button Content="Check for errors" Padding="12,6"
                                                   Command="{Binding CheckErrorsCommand}"
                                                   IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource Not}}" />
                                        <ui:Button Content="Optimize" Padding="12,6" Margin="6,0,0,0" Appearance="Secondary"
                                                   Command="{Binding OptimizeCommand}"
                                                   IsEnabled="{Binding DataContext.IsRunning, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource Not}}" />
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- System files -->
                <TextBlock Text="Windows system files" FontSize="15" FontWeight="SemiBold" Margin="0,8,0,8" />
                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="Scan system files (SFC)" Padding="16,8" Command="{Binding RunSfcCommand}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="DocumentSearch24" />
                        </ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Repair image (DISM)" Padding="16,8" Margin="8,0,0,0" Command="{Binding RunDismCommand}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Wrench24" />
                        </ui:Button.Icon>
                    </ui:Button>
                    <ui:Button Content="Refresh" Padding="16,8" Margin="8,0,0,0" Appearance="Secondary" Command="{Binding RefreshCommand}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="ArrowClockwise24" />
                        </ui:Button.Icon>
                    </ui:Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Live output console -->
        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16"
                                     Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
                    <TextBlock Text="{Binding CurrentOperation}" Margin="8,0,0,0" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <ui:Button Grid.Column="1" Content="Cancel" Appearance="Danger" Padding="14,5"
                           Command="{Binding CancelCommand}"
                           Visibility="{Binding IsRunning, Converter={StaticResource VisibleWhenTrue}}" />
            </Grid>
            <Border Grid.Row="1" Background="#070C14" CornerRadius="6" BorderBrush="{StaticResource CyberStrokeBrush}" BorderThickness="1">
                <TextBox x:Name="OutputBox" Text="{Binding OutputText, Mode=OneWay}" IsReadOnly="True"
                         Background="Transparent" BorderThickness="0" Foreground="#9FE8FF"
                         FontFamily="Consolas, Cascadia Mono, monospace" FontSize="12"
                         TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         Padding="10" TextChanged="OnOutputChanged" />
            </Border>
        </Grid>
    </Grid>
</Page>
