<ui:FluentWindow x:Class="SystemCare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:SystemCare.Views"
        xmlns:controls="clr-namespace:SystemCare.Controls"
        mc:Ignorable="d"
        Title="SystemCare"
        Height="780" Width="1240"
        MinHeight="600" MinWidth="960"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        Background="#0A0E14"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen"
        Loaded="OnLoaded">
    <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform ScaleX="1" ScaleY="1" />
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Ambient cyberpunk backdrop behind the whole shell. -->
        <controls:CyberBackground Grid.Row="0" Grid.RowSpan="2" />

        <ui:TitleBar Grid.Row="0" Title="SYSTEMCARE" FontFamily="{StaticResource DisplayFontFamily}">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/app.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           Background="Transparent"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="False"
                           Transition="FadeInWithSlide"
                           TransitionDuration="260"
                           OpenPaneLength="180">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Dashboard" TargetPageType="{x:Type views:DashboardPage}" ToolTipService.ToolTip="Dashboard">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Auto Care" TargetPageType="{x:Type views:AutoCarePage}" ToolTipService.ToolTip="Auto Care — analyze &amp; fix with one click">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Sparkle24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemHeader Text="Clean" />
                <ui:NavigationViewItem Content="Cleanup" TargetPageType="{x:Type views:CleanupPage}" ToolTipService.ToolTip="Junk Cleanup">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Broom24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Privacy" TargetPageType="{x:Type views:PrivacyPage}" ToolTipService.ToolTip="Privacy Cleaner">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Shield24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Duplicates" TargetPageType="{x:Type views:DuplicateFinderPage}" ToolTipService.ToolTip="Duplicate Finder">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Copy24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="File Shredder" TargetPageType="{x:Type views:FileShredderPage}" ToolTipService.ToolTip="File Shredder (secure delete)">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Delete24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Registry Cleaner" TargetPageType="{x:Type views:RegistryCleanerPage}" ToolTipService.ToolTip="Registry Cleaner">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Database24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Empty Folders" TargetPageType="{x:Type views:EmptyFolderPage}" ToolTipService.ToolTip="Empty Folder Finder">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="FolderProhibited24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemHeader Text="Optimize" />
                <ui:NavigationViewItem Content="Boost" TargetPageType="{x:Type views:BoostPage}" ToolTipService.ToolTip="One-click Boost">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Flash24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Game Mode" TargetPageType="{x:Type views:GameModePage}" ToolTipService.ToolTip="Game / Focus Mode">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Games24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Startup" TargetPageType="{x:Type views:StartupPage}" ToolTipService.ToolTip="Startup Manager">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Rocket24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Windows Tweaks" TargetPageType="{x:Type views:WindowsTweaksPage}" ToolTipService.ToolTip="Windows Tweaks">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Options24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Disk Health" TargetPageType="{x:Type views:DiskHealthPage}" ToolTipService.ToolTip="Disk Health &amp; Maintenance">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Pulse24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Deep Cleanup" TargetPageType="{x:Type views:DeepCleanupPage}" ToolTipService.ToolTip="Deep Windows Cleanup">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Storage24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Driver Updater" TargetPageType="{x:Type views:DriverUpdatePage}" ToolTipService.ToolTip="Driver Updater (via Windows Update)">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DeveloperBoard24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Software Updater" TargetPageType="{x:Type views:SoftwareUpdatePage}" ToolTipService.ToolTip="Update installed apps (winget)">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="ArrowSync24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Software Hub" TargetPageType="{x:Type views:SoftwareHubPage}" ToolTipService.ToolTip="Install popular free apps (winget)">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="AppsAddIn24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Windows Update" TargetPageType="{x:Type views:WindowsUpdatePage}" ToolTipService.ToolTip="Check, install, or pause Windows updates">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="ArrowDownload24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemHeader Text="Analyze" />
                <ui:NavigationViewItem Content="Disk" TargetPageType="{x:Type views:DiskAnalyzerPage}" ToolTipService.ToolTip="Disk Analyzer">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DataPie24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Processes" TargetPageType="{x:Type views:ProcessServicesPage}" ToolTipService.ToolTip="Processes &amp; Services">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="WindowApps24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Network" TargetPageType="{x:Type views:NetworkToolsPage}" ToolTipService.ToolTip="Network Tools">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Globe24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Net Monitor" TargetPageType="{x:Type views:NetworkMonitorPage}" ToolTipService.ToolTip="Per-app bandwidth monitor">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="ArrowTrendingLines24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Security Audit" TargetPageType="{x:Type views:NetworkSecurityAuditPage}" ToolTipService.ToolTip="Network Security Audit (listening ports &amp; firewall)">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Shield24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="System Info" TargetPageType="{x:Type views:SystemInfoPage}" ToolTipService.ToolTip="System Info &amp; Monitor">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Info24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Battery Health" TargetPageType="{x:Type views:BatteryHealthPage}" ToolTipService.ToolTip="Battery Health &amp; wear report">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Battery1024" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="History" TargetPageType="{x:Type views:HistoryPage}" ToolTipService.ToolTip="Activity History">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="History24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Care Report" TargetPageType="{x:Type views:CareReportPage}" ToolTipService.ToolTip="Care Report &amp; Trends">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="DataTrending24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Benchmark" TargetPageType="{x:Type views:BenchmarkPage}" ToolTipService.ToolTip="PC Benchmark &amp; Score">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Gauge24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Sensors" TargetPageType="{x:Type views:SensorsPage}" ToolTipService.ToolTip="Sensors &amp; Thermals">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Temperature24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItemHeader Text="Protect" />
                <ui:NavigationViewItem Content="Bloatware" TargetPageType="{x:Type views:BloatwarePage}" ToolTipService.ToolTip="Bloatware &amp; Store Apps">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Apps24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Debloat" TargetPageType="{x:Type views:DebloatPage}" ToolTipService.ToolTip="Debloat Windows (telemetry, services, bloat apps)">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Broom24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Security" TargetPageType="{x:Type views:SecurityCheckupPage}" ToolTipService.ToolTip="Security Checkup">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="ShieldCheckmark24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Defender" TargetPageType="{x:Type views:DefenderPage}" ToolTipService.ToolTip="Microsoft Defender — status &amp; scan">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="ShieldTask24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Repair Toolkit" TargetPageType="{x:Type views:RepairToolkitPage}" ToolTipService.ToolTip="System Repair Toolkit (SFC / DISM / CHKDSK)">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Wrench24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Reliability" TargetPageType="{x:Type views:ReliabilityPage}" ToolTipService.ToolTip="Reliability Center (crashes &amp; errors)">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Heart24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Rescue Center" TargetPageType="{x:Type views:RescueCenterPage}" ToolTipService.ToolTip="Rescue Center (restore points)">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="ArrowUndo24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                <ui:NavigationViewItem Content="Uninstaller" TargetPageType="{x:Type views:SoftwareUninstallerPage}" ToolTipService.ToolTip="Software Uninstaller">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="AppsListDetail24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Settings" TargetPageType="{x:Type views:SettingsPage}" ToolTipService.ToolTip="Settings">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <ContentPresenter x:Name="RootContentDialog" Grid.Row="0" Grid.RowSpan="2" />

        <ui:SnackbarPresenter x:Name="SnackbarPresenter" Grid.Row="1"
                              VerticalAlignment="Bottom" HorizontalAlignment="Center"
                              MaxWidth="600" Margin="0,0,0,16" />
    </Grid>
</ui:FluentWindow>
