<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:helpers="clr-namespace:SystemCare.Helpers">

    <!-- ============================================================
         CYBERPUNK design-token overrides for WPF-UI (lepo) 3.0.5.
         Merged AFTER ui:ThemesDictionary so these keys win at lookup.
         The accent family (SystemAccent*/AccentFill*) is applied in
         code via ApplicationAccentColorManager.Apply(#00E5FF).
         Unknown keys are harmless (simply unused).
         ============================================================ -->

    <!-- Fonts (bundled, OFL). Orbitron = display/headings, Rajdhani = numerals. -->
    <FontFamily x:Key="DisplayFontFamily">pack://application:,,,/Assets/Fonts/#Orbitron</FontFamily>
    <FontFamily x:Key="LabelFontFamily">pack://application:,,,/Assets/Fonts/#Rajdhani</FontFamily>

    <!-- App / surface backgrounds -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource CyberBackgroundColor}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource CyberBackgroundColor}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseAltBrush" Color="{StaticResource CyberBackgroundDeepColor}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorSecondaryBrush" Color="#0E1420" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorTertiaryBrush" Color="#121A28" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorQuarternaryBrush" Color="#16202E" />

    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource CyberPanelColor}" />
    <SolidColorBrush x:Key="LayerFillColorAltBrush" Color="#121A28" />
    <SolidColorBrush x:Key="LayerOnAcrylicFillColorDefaultBrush" Color="{StaticResource CyberPanelColor}" />

    <!-- Acrylic / flyout / menu backgrounds -->
    <SolidColorBrush x:Key="AcrylicBackgroundFillColorDefaultBrush" Color="#E60B121C" />
    <SolidColorBrush x:Key="AcrylicInAppFillColorDefaultBrush" Color="#E60B121C" />
    <SolidColorBrush x:Key="FlyoutBackgroundBrush" Color="#F00B121C" />

    <!-- Cards (Surface1 glass — resting elevation of the v3 surface scale in Theme.xaml) -->
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#A611192A" />
    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#0E1420" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="{StaticResource CyberStrokeColor}" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultSolidBrush" Color="{StaticResource CyberStrokeColor}" />

    <!-- Controls (inputs, buttons base, combo, etc.) -->
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#16202E" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#1A2636" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="#0E1622" />
    <SolidColorBrush x:Key="ControlFillColorDisabledBrush" Color="#0E1420" />
    <SolidColorBrush x:Key="ControlAltFillColorSecondaryBrush" Color="#16202E" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource CyberStrokeColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="#34466A" />

    <!-- Subtle fills (nav item hover/press, list selection backgrounds) -->
    <SolidColorBrush x:Key="SubtleFillColorSecondaryBrush" Color="#1A2740" />
    <SolidColorBrush x:Key="SubtleFillColorTertiaryBrush" Color="#0E1622" />

    <!-- Strokes / dividers -->
    <SolidColorBrush x:Key="SurfaceStrokeColorDefaultBrush" Color="{StaticResource CyberStrokeColor}" />
    <SolidColorBrush x:Key="SurfaceStrokeColorFlyoutBrush" Color="{StaticResource CyberStrokeColor}" />
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush" Color="#1E2A3D" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrushAlt" Color="{StaticResource CyberStrokeColor}" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
    <!-- v6: raised from #3A4A60 (2.1:1 — unreadably disabled) to ~3.6:1; still clearly inactive. -->
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="#5A6E8C" />

    <!-- Dark text shows on the bright cyan/green accent (buttons etc.) for contrast -->
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#05070B" />
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#0A0E14" />

    <!-- Angular corners for the cyber feel (cards, inputs, flyouts) -->
    <CornerRadius x:Key="ControlCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">4</CornerRadius>

    <!-- ====================  Shared neon styles  ==================== -->

    <!-- Big display heading (Orbitron + cyan glow) -->
    <Style x:Key="CyberDisplayText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFontFamily}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColorPrimaryBrush}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource AccentColor}" ShadowDepth="0" BlurRadius="16" Opacity="0.55" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Page H1 title: bright, readable heading (plain TextBlocks otherwise fall back to dark).
         Rajdhani unifies page titles with the cyber type ramp without Orbitron's width. -->
    <Style x:Key="CyberPageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LabelFontFamily}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColorPrimaryBrush}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource AccentColor}" ShadowDepth="0" BlurRadius="10" Opacity="0.3" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Section header (Orbitron, smaller, subtle glow) -->
    <Style x:Key="CyberSectionHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFontFamily}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource NeonCyanBrush}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource AccentColor}" ShadowDepth="0" BlurRadius="10" Opacity="0.45" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Neon glass card: inherit the WPF-UI Card template; the cyan edge glow now FADES
         in/out via the HoverGlow behavior (code-driven, Freezable-safe, ReduceMotion-aware)
         instead of popping through an Effect trigger. The border swap stays as a trigger
         (a plain value swap, not an animation). -->
    <Style TargetType="{x:Type ui:Card}" BasedOn="{StaticResource {x:Type ui:Card}}">
        <Setter Property="helpers:Animations.HoverGlow" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource NeonCyanBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Press feedback on all WPF-UI buttons: animated press-down / spring-back via the
         PressScale behavior (per-instance transforms, so it dodges the frozen-transform
         issue documented in Animations.cs, and settles instantly under Reduce motion). -->
    <Style TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="helpers:Animations.PressScale" Value="True" />
    </Style>

</ResourceDictionary>
