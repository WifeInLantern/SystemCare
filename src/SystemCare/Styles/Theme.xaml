<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===========================================================
         CYBERPUNK "NIGHT CITY" PALETTE — cyan + magenta on near-black
         These are the single source of truth for the neon theme.
         WPF-UI design-token overrides live in Cyberpunk.xaml.
         =========================================================== -->

    <!-- Surfaces -->
    <Color x:Key="CyberBackgroundColor">#0A0E14</Color>
    <Color x:Key="CyberBackgroundDeepColor">#05070B</Color>
    <Color x:Key="CyberPanelColor">#C8121A28</Color>      <!-- glass panel fill (~78% alpha) -->
    <Color x:Key="CyberPanelSolidColor">#121A28</Color>
    <Color x:Key="CyberStrokeColor">#2A3A55</Color>

    <!-- Neon accents -->
    <Color x:Key="AccentColor">#00E5FF</Color>            <!-- cyan -->
    <Color x:Key="AccentDeepColor">#0091AD</Color>
    <Color x:Key="SecondaryColor">#FF2A6D</Color>         <!-- magenta -->
    <Color x:Key="VioletColor">#B14CFF</Color>

    <!-- Status -->
    <Color x:Key="SuccessColor">#00FFA3</Color>
    <Color x:Key="WarningColor">#FFD300</Color>
    <Color x:Key="DangerColor">#FF2A6D</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#E6F6FF</Color>
    <Color x:Key="TextSecondaryColor">#8FA6C0</Color>
    <Color x:Key="TextTertiaryColor">#5C7290</Color>

    <!-- ===========================  Brushes  =========================== -->
    <SolidColorBrush x:Key="NeonCyanBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="NeonMagentaBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="NeonVioletBrush" Color="{StaticResource VioletColor}" />

    <SolidColorBrush x:Key="CyberPanelBrush" Color="{StaticResource CyberPanelColor}" />
    <SolidColorBrush x:Key="CyberPanelSolidBrush" Color="{StaticResource CyberPanelSolidColor}" />
    <SolidColorBrush x:Key="CyberStrokeBrush" Color="{StaticResource CyberStrokeColor}" />
    <SolidColorBrush x:Key="CyberBackgroundBrush" Color="{StaticResource CyberBackgroundColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="AccentSolidBrush" Color="{StaticResource AccentColor}" />

    <!-- Accent gradient for hero elements: cyan -> magenta diagonal -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
        <GradientStop Color="{StaticResource SecondaryColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Alias kept for older bindings -->
    <LinearGradientBrush x:Key="CyberAccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
        <GradientStop Color="{StaticResource VioletColor}" Offset="0.5" />
        <GradientStop Color="{StaticResource SecondaryColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Subtle top-down panel sheen -->
    <LinearGradientBrush x:Key="CyberPanelGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A2233" Offset="0" />
        <GradientStop Color="#0E1420" Offset="1" />
    </LinearGradientBrush>

    <!-- Deep page background gradient -->
    <LinearGradientBrush x:Key="CyberBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource CyberBackgroundColor}" Offset="0" />
        <GradientStop Color="{StaticResource CyberBackgroundDeepColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Spacing / radius tokens -->
    <CornerRadius x:Key="CardRadius">4</CornerRadius>
    <system:Double xmlns:system="clr-namespace:System;assembly=System.Runtime" x:Key="PagePadding">24</system:Double>

</ResourceDictionary>
