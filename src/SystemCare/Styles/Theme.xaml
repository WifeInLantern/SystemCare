<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Centralized status colors (previously hardcoded across pages) -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FFA726</Color>
    <Color x:Key="DangerColor">#F44336</Color>
    <Color x:Key="AccentColor">#2196F3</Color>
    <Color x:Key="AccentDeepColor">#1565C0</Color>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="AccentSolidBrush" Color="{StaticResource AccentColor}" />

    <!-- Accent gradient for hero elements -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
        <GradientStop Color="{StaticResource AccentDeepColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Spacing / radius tokens -->
    <CornerRadius x:Key="CardRadius">8</CornerRadius>
    <system:Double xmlns:system="clr-namespace:System;assembly=System.Runtime" x:Key="PagePadding">24</system:Double>

</ResourceDictionary>
