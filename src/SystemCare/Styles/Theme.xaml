<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ===========================================================
         CYBERPUNK "NIGHT CITY" PALETTE — cyan + magenta on near-black
         These are the single source of truth for the neon theme.
         WPF-UI design-token overrides live in Cyberpunk.xaml.
         =========================================================== -->

    <!-- Surfaces -->
    <Color x:Key="CyberBackgroundColor">#0A0E14</Color>
    <!-- v4: deepened from #05070B for more contrast under panels (identity anchor CyberBackgroundColor unchanged). -->
    <Color x:Key="CyberBackgroundDeepColor">#03040A</Color>
    <Color x:Key="CyberPanelColor">#C8121A28</Color>      <!-- glass panel fill (~78% alpha) -->
    <Color x:Key="CyberPanelSolidColor">#121A28</Color>
    <Color x:Key="CyberStrokeColor">#2A3A55</Color>

    <!-- Neon accents -->
    <Color x:Key="AccentColor">#00E5FF</Color>            <!-- cyan -->
    <Color x:Key="AccentDeepColor">#0091AD</Color>
    <Color x:Key="SecondaryColor">#FF2A6D</Color>         <!-- magenta -->
    <Color x:Key="VioletColor">#B14CFF</Color>

    <!-- Status -->
    <Color x:Key="SuccessColor">#00FFA3</Color>
    <Color x:Key="WarningColor">#FFD300</Color>
    <Color x:Key="DangerColor">#FF2A6D</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#E6F6FF</Color>
    <Color x:Key="TextSecondaryColor">#8FA6C0</Color>
    <Color x:Key="TextTertiaryColor">#6E86A6</Color> <!-- nudged lighter for contrast on the near-black bg -->

    <!-- ===========================  Brushes  =========================== -->
    <SolidColorBrush x:Key="NeonCyanBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="NeonMagentaBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="NeonVioletBrush" Color="{StaticResource VioletColor}" />

    <SolidColorBrush x:Key="CyberPanelBrush" Color="{StaticResource CyberPanelColor}" />
    <SolidColorBrush x:Key="CyberPanelSolidBrush" Color="{StaticResource CyberPanelSolidColor}" />
    <SolidColorBrush x:Key="CyberStrokeBrush" Color="{StaticResource CyberStrokeColor}" />
    <SolidColorBrush x:Key="CyberBackgroundBrush" Color="{StaticResource CyberBackgroundColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="AccentSolidBrush" Color="{StaticResource AccentColor}" />

    <!-- Accent gradient for hero elements: cyan -> magenta diagonal -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
        <GradientStop Color="{StaticResource SecondaryColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Alias kept for older bindings -->
    <LinearGradientBrush x:Key="CyberAccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentColor}" Offset="0" />
        <GradientStop Color="{StaticResource VioletColor}" Offset="0.5" />
        <GradientStop Color="{StaticResource SecondaryColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Subtle top-down panel sheen -->
    <LinearGradientBrush x:Key="CyberPanelGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A2233" Offset="0" />
        <GradientStop Color="#0E1420" Offset="1" />
    </LinearGradientBrush>

    <!-- Deep page background gradient -->
    <LinearGradientBrush x:Key="CyberBackgroundGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource CyberBackgroundColor}" Offset="0" />
        <GradientStop Color="{StaticResource CyberBackgroundDeepColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- ===========================  Design System v2 tokens  =========================== -->

    <!-- Spacing scale (4px base) -->
    <sys:Double x:Key="SpaceXs">4</sys:Double>
    <sys:Double x:Key="SpaceSm">8</sys:Double>
    <sys:Double x:Key="SpaceMd">12</sys:Double>
    <sys:Double x:Key="SpaceLg">16</sys:Double>
    <sys:Double x:Key="SpaceXl">24</sys:Double>
    <sys:Double x:Key="Space2Xl">32</sys:Double>
    <sys:Double x:Key="PagePadding">24</sys:Double>

    <!-- Common paddings / margins -->
    <Thickness x:Key="PadCard">16,12</Thickness>
    <Thickness x:Key="PadChip">7,3</Thickness>
    <Thickness x:Key="PageMargin">24,12,24,24</Thickness>

    <!-- Radii -->
    <CornerRadius x:Key="CardRadius">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">8</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

    <!-- Semantic surfaces (consolidate one-off page hexes into named tokens) -->
    <SolidColorBrush x:Key="PanelInsetBrush" Color="#12203250" />   <!-- glassy inset behind rows/chips -->
    <SolidColorBrush x:Key="ChipFillBrush" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="ConsoleBackgroundBrush" Color="#070C14" />
    <SolidColorBrush x:Key="ConsoleForegroundBrush" Color="#9FE8FF" />
    <SolidColorBrush x:Key="HairlineBrush" Color="#1E2A3D" />
    <SolidColorBrush x:Key="OverlayScrimBrush" Color="#B305070B" />
    <SolidColorBrush x:Key="FocusGlowBrush" Color="{StaticResource AccentColor}" />

    <!-- Reusable cyan glow levels (static, shareable). v4: pushed one step stronger than v3. -->
    <DropShadowEffect x:Key="GlowSm" Color="{StaticResource AccentColor}" ShadowDepth="0" BlurRadius="12" Opacity="0.40" />
    <DropShadowEffect x:Key="GlowMd" Color="{StaticResource AccentColor}" ShadowDepth="0" BlurRadius="22" Opacity="0.52" />
    <DropShadowEffect x:Key="GlowLg" Color="{StaticResource AccentColor}" ShadowDepth="0" BlurRadius="34" Opacity="0.68" />

    <!-- ===========================  Design System v3 tokens  =========================== -->

    <!-- Elevation / glass surface scale. Alpha increases with elevation so layered panels
         read as stacked glass over the animated backdrop:
         Surface0 = page floor, Surface1 = resting cards, Surface2 = rows/inputs/hover,
         Surface3 = flyouts, dialogs and sticky headers. -->
    <SolidColorBrush x:Key="Surface0Brush" Color="#FF0A0E14" />
    <SolidColorBrush x:Key="Surface1Brush" Color="#A611192A" />
    <SolidColorBrush x:Key="Surface2Brush" Color="#C81A2438" />
    <!-- v4: alpha raised from #E6 for a clearer "lifted above everything" read on dialogs/flyouts. -->
    <SolidColorBrush x:Key="Surface3Brush" Color="#F0202C46" />

    <!-- 1px "rim light" stroke that sells the glass: bright at the top edge, fading to stroke. -->
    <LinearGradientBrush x:Key="GlassRimBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3DFFFFFF" Offset="0" />
        <GradientStop Color="#1A2A3A55" Offset="0.35" />
        <GradientStop Color="#142A3A55" Offset="1" />
    </LinearGradientBrush>

    <!-- Optional top-sheen overlay fill for glass panels. -->
    <LinearGradientBrush x:Key="GlassSheenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#14FFFFFF" Offset="0" />
        <GradientStop Color="#00FFFFFF" Offset="0.25" />
    </LinearGradientBrush>

    <!-- Translucent status fills (~20% alpha) for chips and badges, with matching strokes. -->
    <SolidColorBrush x:Key="SuccessSubtleBrush" Color="#3300FFA3" />
    <SolidColorBrush x:Key="WarningSubtleBrush" Color="#33FFD300" />
    <SolidColorBrush x:Key="DangerSubtleBrush" Color="#33FF2A6D" />
    <SolidColorBrush x:Key="InfoSubtleBrush" Color="#3300E5FF" />
    <SolidColorBrush x:Key="VioletSubtleBrush" Color="#33B14CFF" />
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="#2200E5FF" />
    <!-- Soft danger text: readable pink for error captions sitting on DangerSubtleBrush. -->
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#FF8AA8" />

    <SolidColorBrush x:Key="SuccessSubtleStroke" Color="#5500FFA3" />
    <SolidColorBrush x:Key="WarningSubtleStroke" Color="#55FFD300" />
    <SolidColorBrush x:Key="DangerSubtleStroke" Color="#55FF2A6D" />
    <SolidColorBrush x:Key="InfoSubtleStroke" Color="#5500E5FF" />
    <SolidColorBrush x:Key="VioletSubtleStroke" Color="#55B14CFF" />

    <!-- Positive-stat gradient: mint -> cyan diagonal (health, space freed, benchmark wins). -->
    <LinearGradientBrush x:Key="SuccessGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource SuccessColor}" Offset="0" />
        <GradientStop Color="{StaticResource AccentColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Colored glow variants so danger/success glows stop being inlined per page.
         Glow law: Sm = static accents, Md = hover states, Lg = at most 1-2 hero elements per page.
         v4: pushed to match the Sm/Md bump above. -->
    <DropShadowEffect x:Key="GlowMagentaMd" Color="{StaticResource SecondaryColor}" ShadowDepth="0" BlurRadius="20" Opacity="0.58" />
    <DropShadowEffect x:Key="GlowSuccessSm" Color="{StaticResource SuccessColor}" ShadowDepth="0" BlurRadius="12" Opacity="0.40" />

    <!-- ===========================  Design System v4 tokens  =========================== -->

    <!-- Violet accent glow (Md tier), matching GlowMagentaMd/GlowSuccessSm — v3 shipped a violet
         accent color and VioletSubtleBrush/Stroke pair but no matching glow. -->
    <DropShadowEffect x:Key="GlowVioletMd" Color="{StaticResource VioletColor}" ShadowDepth="0" BlurRadius="20" Opacity="0.55" />

    <!-- Reserved for the single loudest hero element in the whole app (e.g. the health gauge) -
         NOT a per-page tier like GlowLg (which allows 1-2 heroes per page). Use at most once. -->
    <DropShadowEffect x:Key="GlowXl" Color="{StaticResource AccentColor}" ShadowDepth="0" BlurRadius="44" Opacity="0.75" />

    <!-- ===========================  Design System v6 tokens ("Night City, Refined")  ===========================
         See docs/UI-REDESIGN-V5.md. v6 law: Opacity is never applied to text — hierarchy comes from
         the four text brushes below (primary/secondary/tertiary/quaternary) and the type ramp. -->

    <!-- Legitimate 4th de-emphasis tier (~3.2:1) for watermarks/ghost hints at >=18px only —
         exists so pages stop reaching for Opacity="0.5" on text. -->
    <Color x:Key="TextQuaternaryColor">#586C88</Color>
    <SolidColorBrush x:Key="TextQuaternaryBrush" Color="{StaticResource TextQuaternaryColor}" />

    <!-- Hero-to-content separation on hub/landing compositions. -->
    <sys:Double x:Key="Space3Xl">48</sys:Double>

    <!-- Max content width for scrolling pages (long-line reading + centered composition on wide monitors). -->
    <sys:Double x:Key="ContentMaxWidth">1100</sys:Double>

</ResourceDictionary>
