<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:helpers="clr-namespace:SystemCare.Helpers">

    <!-- ============================================================
         DESIGN SYSTEM v2 — reusable component styles.
         Merged AFTER Cyberpunk.xaml so BasedOn picks up the themed
         base styles. Existing keys (CyberPageTitle, CyberSectionHeader,
         NeonCyanBrush, …) are left intact in the other dictionaries.
         ============================================================ -->

    <!--  ==========  Typography ramp  ==========  -->

    <!-- v6 ("Night City, Refined") widened the ramp: the old 15/13/13/11 spread was so compressed
         that pages kept inventing inline sizes. Body/captions also gain breathing room via LineHeight.
         v6 law: never set Opacity on text — hierarchy comes from the text brushes + this ramp. -->

    <Style x:Key="TextH2" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColorPrimaryBrush}" />
        <Setter Property="Margin" Value="0,16,0,8" />
    </Style>

    <Style x:Key="TextBody" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColorSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="TextCaption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="17" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColorTertiaryBrush}" />
    </Style>

    <!-- Sub-section header: covers the tier pages previously faked with FontSize=12 SemiBold. -->
    <Style x:Key="TextH3" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColorPrimaryBrush}" />
        <Setter Property="Margin" Value="0,12,0,6" />
    </Style>

    <!-- Emphasised inline label (replaces ad-hoc FontWeight=SemiBold on primary text). -->
    <Style x:Key="TextBodyStrong" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColorPrimaryBrush}" />
    </Style>

    <!-- Right-aligned numeric value (sizes, speeds, durations) in the label numeral font. -->
    <Style x:Key="TextMetricValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LabelFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColorPrimaryBrush}" />
        <Setter Property="TextAlignment" Value="Right" />
    </Style>

    <!-- v6: the big live numbers (CPU %, RAM, hero stats) — replaces inline FontSize="32" FontWeight="Bold". -->
    <Style x:Key="TextMetricHero" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LabelFontFamily}" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColorPrimaryBrush}" />
    </Style>

    <!--  ==========  Buttons  ==========  -->

    <!-- Hover glows are the HoverGlow behavior (fade in/out) rather than Effect triggers,
         so the glow eases instead of popping. PressScale comes from the implicit ui:Button. -->
    <Style x:Key="CyberPrimaryButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Appearance" Value="Primary" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="helpers:Animations.HoverGlow" Value="True" />
    </Style>

    <Style x:Key="CyberGhostButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Appearance" Value="Secondary" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="BorderBrush" Value="{StaticResource CyberStrokeBrush}" />
        <Setter Property="helpers:Animations.HoverGlow" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource NeonCyanBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="CyberDangerButton" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
        <Setter Property="Appearance" Value="Danger" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="helpers:Animations.HoverGlow" Value="True" />
        <Setter Property="helpers:Animations.HoverGlowColor" Value="{StaticResource DangerColor}" />
    </Style>

    <!--  ==========  Inputs: app-wide neon focus glow (implicit)  ==========  -->

    <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="{StaticResource AccentColor}" ShadowDepth="0" BlurRadius="12" Opacity="0.5" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="{StaticResource AccentColor}" ShadowDepth="0" BlurRadius="10" Opacity="0.45" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  ==========  Cards  ==========  -->

    <!-- Glass card (the implicit ui:Card style already adds the hover edge-glow). -->
    <Style x:Key="CyberCard" TargetType="ui:Card" BasedOn="{StaticResource {x:Type ui:Card}}">
        <Setter Property="Padding" Value="{StaticResource PadCard}" />
    </Style>

    <!-- Interactive card: scale + glow lift on hover, baked in via the attached behavior.
         HoverGlow (inherited from the implicit ui:Card style) is disabled because HoverLift
         already owns the element's Effect — the two must never share one element. -->
    <Style x:Key="CyberInteractiveCard" TargetType="ui:Card" BasedOn="{StaticResource {x:Type ui:Card}}">
        <Setter Property="Padding" Value="{StaticResource PadCard}" />
        <Setter Property="helpers:Animations.HoverGlow" Value="False" />
        <Setter Property="helpers:Animations.HoverLift" Value="True" />
        <!-- Accessible keyboard-focus ring for clickable cards. -->
        <Setter Property="FocusVisualStyle" Value="{StaticResource CyberFocusVisual}" />
    </Style>

    <!--  ==========  Glass panels (hand-rolled glass surfaces for page-built layouts)  ==========  -->

    <!-- Resting glass panel: Surface1 fill + the 1px rim-light stroke that sells the glass. -->
    <Style x:Key="CyberGlassPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface1Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassRimBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="{StaticResource PadCard}" />
    </Style>

    <!-- Raised glass panel: one elevation step up (rows, inputs, hover surfaces). -->
    <Style x:Key="CyberGlassPanelRaised" TargetType="Border" BasedOn="{StaticResource CyberGlassPanel}">
        <Setter Property="Background" Value="{StaticResource Surface2Brush}" />
    </Style>

    <!--  ==========  Chips / inset rows / console  ==========  -->

    <Style x:Key="CyberChip" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ChipFillBrush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="{StaticResource PadChip}" />
    </Style>

    <!-- Status chips: translucent status fill + matching stroke (tokens from Theme.xaml). -->
    <Style x:Key="CyberChipSuccess" TargetType="Border" BasedOn="{StaticResource CyberChip}">
        <Setter Property="Background" Value="{StaticResource SuccessSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SuccessSubtleStroke}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="CyberChipWarning" TargetType="Border" BasedOn="{StaticResource CyberChip}">
        <Setter Property="Background" Value="{StaticResource WarningSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource WarningSubtleStroke}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="CyberChipDanger" TargetType="Border" BasedOn="{StaticResource CyberChip}">
        <Setter Property="Background" Value="{StaticResource DangerSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerSubtleStroke}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="CyberChipInfo" TargetType="Border" BasedOn="{StaticResource CyberChip}">
        <Setter Property="Background" Value="{StaticResource InfoSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InfoSubtleStroke}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Chip label text, matched to the status color. -->
    <Style x:Key="ChipTextSuccess" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
    </Style>
    <Style x:Key="ChipTextWarning" TargetType="TextBlock" BasedOn="{StaticResource ChipTextSuccess}">
        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
    </Style>
    <Style x:Key="ChipTextDanger" TargetType="TextBlock" BasedOn="{StaticResource ChipTextSuccess}">
        <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
    </Style>
    <Style x:Key="ChipTextInfo" TargetType="TextBlock" BasedOn="{StaticResource ChipTextSuccess}">
        <Setter Property="Foreground" Value="{StaticResource NeonCyanBrush}" />
    </Style>

    <!-- Neutral / disabled chip (replaces ad-hoc inline #33445566 fills). -->
    <Style x:Key="CyberChipNeutral" TargetType="Border" BasedOn="{StaticResource CyberChip}">
        <Setter Property="Background" Value="{StaticResource Surface2Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CyberStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style x:Key="ChipTextNeutral" TargetType="TextBlock" BasedOn="{StaticResource ChipTextSuccess}">
        <Setter Property="Foreground" Value="{StaticResource TextFillColorSecondaryBrush}" />
    </Style>

    <!-- Accessible keyboard-focus ring for custom-drawn controls and interactive cards that
         otherwise suppress the default focus adorner. Apply via FocusVisualStyle. -->
    <Style x:Key="CyberFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="2"
                            CornerRadius="8" Margin="-2" SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ==========  Skeleton loading placeholders  ==========  -->

    <!-- Shimmering placeholder line; show behind FadeVisible="{Binding IsBusy}" while loading. -->
    <Style x:Key="SkeletonBlock" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface2Brush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="helpers:Animations.Shimmer" Value="True" />
    </Style>

    <!-- Card-sized placeholder for list/grid results. -->
    <Style x:Key="SkeletonCard" TargetType="Border" BasedOn="{StaticResource SkeletonBlock}">
        <Setter Property="Height" Value="64" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
    </Style>

    <!--  ==========  Empty states  ==========
          Composition pattern (no dedicated control): a centered StackPanel of
          [ui:SymbolIcon FontSize=40 Opacity=0.4] + EmptyStateTitle + EmptyStateHint
          + optional CyberGhostButton.  -->

    <Style x:Key="EmptyStateTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource LabelFontFamily}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextFillColorSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,12,0,4" />
    </Style>

    <Style x:Key="EmptyStateHint" TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxWidth" Value="360" />
    </Style>

    <Style x:Key="CyberListRow" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelInsetBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="CyberConsole" TargetType="TextBox">
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource ConsoleForegroundBrush}" />
        <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
    </Style>

    <!--  ==========  Page root: bright inherited text (removes per-page boilerplate)  ==========  -->
    <Style TargetType="Page">
        <Setter Property="TextElement.Foreground" Value="{StaticResource TextFillColorPrimaryBrush}" />
    </Style>

</ResourceDictionary>
