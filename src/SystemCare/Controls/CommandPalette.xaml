<UserControl x:Class="SystemCare.Controls.CommandPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:helpers="clr-namespace:SystemCare.Helpers"
             Visibility="Collapsed"
             TextElement.Foreground="{StaticResource TextFillColorPrimaryBrush}">
    <Grid>
        <!-- Scrim: dims the app and closes the palette on click. Token fill + opacity (no inline literal). -->
        <Border Background="{StaticResource Surface0Brush}" Opacity="0.72" MouseLeftButtonDown="OnScrimClick" />

        <!-- Palette panel -->
        <Border Width="580" MaxHeight="470" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,110,0,0" Padding="8" CornerRadius="8"
                Background="{StaticResource Surface2Brush}"
                BorderBrush="{StaticResource CyberStrokeBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ui:TextBox x:Name="SearchBox" Grid.Row="0" Margin="4" MinHeight="38" FontSize="14"
                            PlaceholderText="Search tools…   (Esc to close)"
                            PreviewKeyDown="OnSearchKeyDown" TextChanged="OnSearchChanged">
                    <ui:TextBox.Icon>
                        <ui:SymbolIcon Symbol="Search24" />
                    </ui:TextBox.Icon>
                </ui:TextBox>

                <ListBox x:Name="ResultsList" Grid.Row="1" Margin="4,8,4,4" MaxHeight="380"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseLeftButtonUp="OnResultsClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="6,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Category}" Style="{StaticResource TextCaption}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
