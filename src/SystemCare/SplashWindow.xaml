<Window x:Class="SystemCare.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen">
    <!-- Layout mirrors Assets/splash.png so the native splash hands off without a visible jump. -->
    <Border Width="380" Height="240" CornerRadius="18"
            Background="#1E1E1E" BorderBrush="#3A3A3A" BorderThickness="1">
        <Grid>
            <!-- Pulsing, glowing logo (matches png badge at y=38) -->
            <Image Source="pack://application:,,,/Assets/app.png" Width="76" Height="76"
                   VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,38,0,0"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1" />
                </Image.RenderTransform>
                <Image.Effect>
                    <DropShadowEffect x:Name="LogoGlow" Color="#2196F3" ShadowDepth="0" BlurRadius="24" Opacity="0.5" />
                </Image.Effect>
            </Image>

            <TextBlock Text="SystemCare" FontSize="21" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,142,0,0" />

            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,26">
                <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" />
                <TextBlock Text="Starting…" Foreground="#9A9EA2" FontSize="12"
                           VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>
        </Grid>
    </Border>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Fade the whole window in -->
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25" />
                    <!-- Gentle logo pulse -->
                    <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleX"
                                     From="0.92" To="1.06" Duration="0:0:1.1" AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleY"
                                     From="0.92" To="1.06" Duration="0:0:1.1" AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <!-- Glow breathing in sync -->
                    <DoubleAnimation Storyboard.TargetName="LogoGlow" Storyboard.TargetProperty="Opacity"
                                     From="0.3" To="0.75" Duration="0:0:1.1" AutoReverse="True" RepeatBehavior="Forever">
                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
